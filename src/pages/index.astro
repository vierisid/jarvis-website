---
// Home — Brand Book III ("Monochrome Lab") · ported verbatim from the
// design source: Design/usejarvis-home-FABLE5.html. Styles and script use
// is:inline so Astro emits them exactly as authored (no scoping, no CSS
// rewriting, no bundling) — a 1:1 reproduction of the canonical design.
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Usejarvis · The agentic layer humans can work with</title>
<meta name="description" content="An operating system for AI agents: an always-on runtime on your machine that works your apps on screen while you watch. Runs local models or your own keys, and it asks before anything irreversible." />
<link rel="icon" href='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><style>path{fill:%2313161A}@media(prefers-color-scheme:dark){path{fill:%23EEF1F4}}</style><path d="M29 3 L29 16 A13 13 0 1 1 16 3 Z"/></svg>'>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Familjen+Grotesk:ital,wght@0,400..700;1,400&family=Spline+Sans+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style is:inline>
  *{margin:0;padding:0;box-sizing:border-box;}
  :root{
    --sans:'Familjen Grotesk',system-ui,sans-serif;--mono:'Spline Sans Mono',ui-monospace,monospace;
    /* Brand Book III · cool-tinted neutrals, light */
    --bg:#FAFBFC;--raise:#FFFFFF;--panel:#EFF2F5;--panel2:#F6F8FA;--rule:#E2E7EC;--rule2:#EDF0F3;
    --ink:#13161A;--ink2:#535B63;--ink3:#677077;--faint:#9AA2AB;
    /* state hues + AA text */
    --listen:#E63B2E;--listen-tx:#C2301F;--speak:#2D78FF;--speak-tx:#1E5FD8;
    --hold:#EAA40E;--hold-tx:#8A6206;--ok:#2FA45E;--ok-tx:#1F7A43;
    --corner:14px 3px 14px 14px;--corner-sm:9px 2px 9px 9px;--ease:cubic-bezier(.2,.7,.2,1);
    --sh-sm:0 1px 2px rgba(20,30,45,.06),0 1px 1px rgba(20,30,45,.04);
    --sh-md:0 2px 6px rgba(20,30,45,.06),0 10px 24px -10px rgba(20,30,45,.18);
    --sh-lg:0 3px 8px rgba(20,30,45,.05),0 22px 48px -18px rgba(20,30,45,.24);
  }
  html{scroll-behavior:smooth;}
  body{background:var(--bg);color:var(--ink);font-family:var(--sans);-webkit-font-smoothing:antialiased;overflow-x:hidden;}
  ::selection{background:rgba(230,59,46,.22);}
  .wrap{max-width:1100px;margin:0 auto;padding:0 32px;}
  @media (max-width:700px){.wrap{padding:0 20px}}
  h1,h2,h3{text-wrap:balance;}
  .btn{font-weight:600;border-radius:var(--corner-sm);display:inline-flex;align-items:center;gap:8px;font-size:14px;padding:12px 20px;text-decoration:none;cursor:pointer;color:var(--ink);}
  .btn.solid{background:var(--ink);color:var(--bg);box-shadow:var(--sh-sm);}
  .btn.out{border:1px solid var(--rule);background:rgba(255,255,255,.6);box-shadow:var(--sh-sm);}
  .ld{position:relative;flex-shrink:0;}.ld .r{position:absolute;inset:0;border:2px solid var(--ink);border-radius:50% 5px 50% 50%;}
  .lw{font-weight:700;letter-spacing:-.045em;color:var(--ink);}.lw .u{color:var(--ink3);}

  /* ── the drop ── */
  .gd{position:relative;overflow:hidden;border-radius:50% 50% 50% 8px;transform:rotate(45deg);background:rgba(255,255,255,.07);border:.5px solid rgba(255,255,255,.55);
    -webkit-backdrop-filter:blur(2px) brightness(1.04) saturate(1.15) url(#refract);backdrop-filter:blur(2px) brightness(1.04) saturate(1.15) url(#refract);
    box-shadow:inset 1.5px 1.5px 1.5px rgba(255,255,255,.92),inset -1px -1px 2px rgba(255,255,255,.4),0 4px 14px -3px rgba(20,30,45,.3);}
  .gd .in{position:absolute;inset:0;border-radius:inherit;opacity:0;}
  .gd .ring{position:absolute;inset:-2px;border-radius:inherit;opacity:0;background:conic-gradient(from 0deg,transparent 0 200deg,rgba(255,255,255,.98) 300deg,transparent 360deg);
    -webkit-mask:radial-gradient(circle,transparent 38%,#000 45%,#000 56%,transparent 63%);mask:radial-gradient(circle,transparent 38%,#000 45%,#000 56%,transparent 63%);}
  @keyframes br{0%,100%{opacity:.55}50%{opacity:1}}
  @keyframes brS{0%,100%{opacity:.7;transform:scale(.94)}50%{opacity:1;transform:scale(1.04)}}
  @keyframes spin{to{transform:rotate(360deg)}}
  @keyframes askGlow{0%,100%{box-shadow:inset 1.5px 1.5px 1.5px rgba(255,255,255,.92),0 0 0 0 rgba(234,164,14,.45),0 4px 14px -3px rgba(20,30,45,.3)}50%{box-shadow:inset 1.5px 1.5px 1.5px rgba(255,255,255,.92),0 0 0 7px rgba(234,164,14,0),0 4px 14px -3px rgba(20,30,45,.3)}}
  @keyframes dfl{0%{opacity:0;transform:scale(.55)}30%{opacity:1}100%{opacity:0;transform:scale(1.18)}}
  .gd.s-listen .in{opacity:1;animation:br 1.4s infinite;background:radial-gradient(circle,rgba(230,59,46,.92),rgba(230,59,46,.28) 55%,transparent 72%);}
  .gd.s-listen{box-shadow:inset 1.5px 1.5px 1.5px rgba(255,255,255,.92),inset -1px -1px 2px rgba(255,255,255,.4),0 6px 18px -4px rgba(230,59,46,.42),0 2px 6px rgba(20,30,45,.2);}
  .gd.s-speak .in{opacity:1;animation:brS 1.6s infinite;background:radial-gradient(circle,rgba(45,120,255,1),rgba(45,120,255,.5) 48%,transparent 72%);}
  .gd.s-think .ring{opacity:1;animation:spin 1.4s linear infinite;}
  .gd.s-ask .in{opacity:1;animation:br 2s infinite;background:radial-gradient(circle,rgba(234,164,14,.85),rgba(234,164,14,.25) 55%,transparent 72%);}
  .gd.s-ask{animation:askGlow 2s var(--ease) infinite;}
  .gd.s-done .in{opacity:0;animation:dfl .9s var(--ease) both;background:radial-gradient(circle,rgba(47,164,94,.95),rgba(47,164,94,.3) 55%,transparent 72%);}

  /* cursor pebble · carried liquid */
  #cpeb{position:fixed;top:0;left:0;width:28px;height:28px;pointer-events:none;z-index:9999;will-change:transform;transform:translate(72vw,200px) rotate(45deg);}
  #cpeb .gd{width:28px;height:28px;border-radius:50% 50% 50% 5px;background:rgba(255,255,255,.14);border:.5px solid rgba(20,30,45,.35);box-shadow:inset 1px 1px 1.5px rgba(255,255,255,.95),inset -1px -1px 2px rgba(255,255,255,.4),0 3px 10px -2px rgba(20,30,45,.4);}
  #cpeb .gd .in{opacity:.65;background:radial-gradient(circle,rgba(230,59,46,.7),transparent 70%);transition:opacity .35s;}
  #cpeb.moving .gd .in{opacity:.9;}

  /* ── nav ── */
  nav{position:sticky;top:0;z-index:50;background:color-mix(in srgb,var(--bg) 82%,transparent);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);border-bottom:1px solid var(--rule);}
  .nav-in{max-width:1100px;margin:0 auto;padding:0 32px;height:62px;display:flex;align-items:center;justify-content:space-between;}
  .nav-l{display:flex;align-items:center;gap:10px;}.nav-l .ld{width:23px;height:23px;}.nav-l .lw{font-size:16px;}
  .nav-links{display:flex;gap:22px;font-size:13.5px;color:var(--ink2);font-weight:500;margin-left:10px;}
  .nav-links a{color:var(--ink2);text-decoration:none;}.nav-links a:hover{color:var(--ink);}
  @media (max-width:860px){.nav-links{display:none}}
  .nav-r{display:flex;align-items:center;gap:12px;}
  .nav-status{display:inline-flex;align-items:center;gap:7px;font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink2);border:1px solid var(--rule);border-radius:999px;padding:5px 11px;}
  .nav-status .d{width:6px;height:6px;border-radius:50%;background:var(--listen);box-shadow:0 0 0 3px rgba(230,59,46,.14);animation:br 1.3s infinite;}
  @media (max-width:560px){.nav-status{display:none}}
  #menuBtn{display:none;font-family:var(--sans);font-size:13px;font-weight:600;color:var(--ink);background:transparent;border:1px solid var(--rule);border-radius:var(--corner-sm);padding:8px 13px;cursor:pointer;}
  @media (max-width:860px){#menuBtn{display:inline-flex}}
  #mobnav{display:none;position:absolute;top:62px;right:20px;width:220px;flex-direction:column;border-radius:var(--corner);overflow:hidden;background:color-mix(in srgb,var(--raise) 75%,transparent);-webkit-backdrop-filter:blur(16px) saturate(1.4);backdrop-filter:blur(16px) saturate(1.4);border:.5px solid var(--rule);box-shadow:var(--sh-lg);z-index:60;}
  #mobnav.open{display:flex;}
  #mobnav a{padding:13px 18px;font-size:14.5px;font-weight:500;color:var(--ink);text-decoration:none;border-bottom:1px solid var(--rule2);}
  #mobnav a:last-child{border-bottom:none;}

  /* ── hero · Book III grammar: the pebble at full scale, lit ── */
  .hero{position:relative;overflow:hidden;text-align:center;padding:86px 0 92px;background:radial-gradient(620px 430px at 50% 26%,rgba(230,59,46,.13),rgba(230,59,46,.03) 48%,transparent 70%),linear-gradient(180deg,var(--panel2),var(--bg));border-bottom:1px solid var(--rule);}
  .hero .gridbg{position:absolute;inset:0;background:linear-gradient(rgba(19,22,26,.035) 1px,transparent 1px) 0 0/32px 32px,linear-gradient(90deg,rgba(19,22,26,.035) 1px,transparent 1px) 0 0/32px 32px;-webkit-mask:radial-gradient(660px 450px at 50% 30%,#000,transparent 70%);mask:radial-gradient(660px 450px at 50% 30%,#000,transparent 70%);}
  .hero .in2{position:relative;z-index:2;}
  @keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  @keyframes pebin{0%{opacity:0;transform:scale(.6)}100%{opacity:1;transform:none}}
  .hero .k{font-size:16px;font-weight:600;color:var(--ink2);animation:rise .7s var(--ease) both;}
  .hero .bigpeb{width:124px;height:124px;margin:26px auto 26px;position:relative;display:flex;align-items:center;justify-content:center;animation:pebin .9s var(--ease) both .15s;}
  .hero .bigpeb::before{content:"";position:absolute;width:250px;height:250px;border-radius:50%;background:radial-gradient(circle,rgba(230,59,46,.26),transparent 66%);filter:blur(10px);}
  .hero .bigpeb .gd{width:124px;height:124px;border-radius:50% 50% 50% 23px;}
  .hero .bigpeb .gd .ring{inset:-3px;}
  .hero h1{font-size:clamp(42px,5.6vw,74px);font-weight:700;letter-spacing:-.045em;line-height:.96;max-width:16ch;margin:0 auto;animation:rise .7s var(--ease) both .3s;}
  .hero h1 em{font-style:normal;color:var(--ink3);}
  .hero .lede{font-size:18px;line-height:1.55;color:var(--ink2);max-width:46ch;margin:20px auto 0;animation:rise .7s var(--ease) both .42s;}
  .hero .cta{display:flex;gap:11px;justify-content:center;margin-top:28px;flex-wrap:wrap;animation:rise .7s var(--ease) both .52s;}
  .hero .hint{margin-top:28px;font-family:var(--mono);font-size:11px;color:var(--ink3);animation:rise .7s var(--ease) both .62s;}
  .hero .watch{margin-top:16px;font-size:13.5px;}
  .hero .watch a{color:var(--ink2);text-decoration:underline;text-underline-offset:3px;}

  /* ── sections ── */
  .section{padding:clamp(72px,9vw,104px) 0;border-top:1px solid var(--rule);}
  .section.alt{background:var(--panel2);}
  .sec-h{font-size:clamp(28px,3.6vw,44px);font-weight:700;letter-spacing:-.04em;line-height:1.02;max-width:22ch;}
  .sec-h em{font-style:normal;color:var(--ink3);}
  .sec-sub{font-size:16px;color:var(--ink2);line-height:1.55;margin-top:14px;max-width:56ch;}
  .sec-sub b{color:var(--ink);font-weight:600;}
  .split{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center;}
  @media (max-width:880px){.split{grid-template-columns:1fr;gap:30px}}
  .rv{opacity:1;transform:none;transition:opacity .6s var(--ease),transform .6s var(--ease);}
  .js .rv{opacity:0;transform:translateY(18px);}
  .js .rv.vis{opacity:1;transform:none;}

  /* ── the demo · jarvis books, you approve ── */
  .demo{position:relative;height:380px;border-radius:var(--corner);overflow:hidden;box-shadow:var(--sh-lg);
    background:repeating-linear-gradient(118deg,rgba(60,80,110,.05) 0 15px,transparent 15px 30px),linear-gradient(155deg,#cdd4dd,#b5bec9);}
  .demo .dwin{position:absolute;left:5%;right:5%;top:26px;bottom:26px;border-radius:12px;background:rgba(255,255,255,.6);box-shadow:inset 0 0 0 1px rgba(255,255,255,.55),0 14px 32px -18px rgba(20,30,45,.32);}
  .demo .tb{position:absolute;left:5%;right:5%;top:26px;height:36px;background:rgba(255,255,255,.65);border-radius:12px 12px 0 0;border-bottom:1px solid rgba(20,30,45,.07);display:flex;align-items:center;gap:8px;padding:0 14px;}
  .demo .tb i{width:9px;height:9px;border-radius:50%;background:rgba(20,30,45,.13);}
  .demo .tb span{font-family:var(--mono);font-size:9.5px;color:#5A6470;letter-spacing:.06em;margin-left:6px;}
  .fld{position:absolute;left:12%;width:44%;height:42px;border-radius:8px;background:rgba(255,255,255,.78);box-shadow:inset 0 0 0 1px rgba(20,30,45,.08);padding:6px 12px;transition:box-shadow .3s var(--ease);}
  .fld.hot{box-shadow:inset 0 0 0 1.5px var(--listen),0 0 0 4px rgba(230,59,46,.13);}
  .fld .flab{display:block;font-family:var(--mono);font-size:7.5px;letter-spacing:.12em;text-transform:uppercase;color:#7A828D;}
  .fld .ftxt{display:block;font-size:13px;color:#1A2027;font-weight:500;min-height:17px;}
  .fld .ftxt::after{content:"";display:inline-block;width:1px;height:11px;background:transparent;vertical-align:-1px;}
  .fld.typing .ftxt::after{background:#1A2027;animation:br .8s steps(1) infinite;}
  #f1{top:92px;}#f2{top:148px;}
  .paybtn{position:absolute;left:12%;top:212px;font-family:var(--sans);font-size:13px;font-weight:600;padding:11px 22px;border:none;border-radius:9px 2px 9px 9px;background:#1A2027;color:#fff;box-shadow:0 3px 10px -3px rgba(20,30,45,.4);transition:box-shadow .3s var(--ease);}
  .paybtn.hot{box-shadow:0 0 0 1.5px var(--hold),0 0 0 5px rgba(234,164,14,.18),0 3px 10px -3px rgba(20,30,45,.4);}
  .paybtn.paid{background:#1F7A43;}
  .cur{position:absolute;left:0;top:0;display:flex;align-items:flex-start;filter:drop-shadow(0 2px 3px rgba(20,30,45,.4));z-index:6;will-change:transform;transition:transform 1s var(--ease);}
  .cur .tag{position:absolute;top:30px;left:14px;font-family:var(--mono);font-size:8.5px;letter-spacing:.12em;text-transform:uppercase;padding:3px 7px;border-radius:5px;font-weight:600;white-space:nowrap;}
  .cur.j .tag{background:var(--listen);color:#fff;}
  .cur.y .tag{background:#13161A;color:#fff;}
  .cur.j .gd{width:26px;height:26px;border-radius:50% 50% 50% 5px;margin:13px 0 0 5px;}
  .appr{position:absolute;right:7%;top:84px;width:250px;border-radius:13px 4px 13px 13px;overflow:hidden;z-index:5;
    background:rgba(255,255,255,.6);-webkit-backdrop-filter:blur(16px) saturate(1.4);backdrop-filter:blur(16px) saturate(1.4);
    box-shadow:inset 0 1px 1px rgba(255,255,255,.6),inset 0 0 0 .5px rgba(20,30,45,.09),0 18px 40px -16px rgba(20,30,45,.45);border:.5px solid rgba(255,255,255,.5);
    opacity:0;transform:scale(.7);transform-origin:30% 110%;transition:opacity .42s var(--ease),transform .42s var(--ease);pointer-events:none;}
  .appr.show{opacity:1;transform:none;}
  .appr .ah{padding:12px 14px 8px;}
  .appr .ah .t{font-size:13px;font-weight:700;color:#15191E;}
  .appr .ah .s{font-family:var(--mono);font-size:8px;letter-spacing:.1em;text-transform:uppercase;color:var(--hold-tx);margin-top:3px;}
  .appr .ab{padding:0 14px 10px;font-size:11.5px;color:#3D454E;line-height:1.45;}
  .appr .ac{display:flex;gap:7px;padding:0 12px 12px;}
  .appr .ac span{flex:1;text-align:center;font-size:11.5px;font-weight:600;padding:8px 0;border-radius:7px 2px 7px 7px;}
  .appr .ac .a1{background:#15191E;color:#fff;transition:transform .18s var(--ease),box-shadow .18s var(--ease);}
  .appr .ac .a1.press{transform:scale(.93);box-shadow:0 0 0 4px rgba(47,164,94,.25);}
  .appr .ac .a2{border:1px solid rgba(20,30,45,.14);color:#15191E;}
  .toast{position:absolute;right:7%;bottom:38px;display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:10.5px;color:#fff;background:#15191E;border-radius:9px 2px 9px 9px;padding:9px 14px;box-shadow:0 10px 26px -10px rgba(20,30,45,.5);
    opacity:0;transform:translateY(8px);transition:opacity .4s var(--ease),transform .4s var(--ease);}
  .toast.show{opacity:1;transform:none;}
  .toast .d{width:7px;height:7px;border-radius:50%;background:var(--ok);}
  @media (max-width:700px){.demo{height:460px}.appr{top:258px;width:222px;right:6%;transform-origin:30% -20%;}}
  .demo .cap{position:absolute;left:50%;bottom:10px;transform:translateX(-50%);font-family:var(--mono);font-size:8.5px;letter-spacing:.14em;text-transform:uppercase;color:#46505C;white-space:nowrap;}

  /* ── say this ── */
  .says{margin-top:34px;border-top:1px solid var(--ink);}
  .sayrow{display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:center;padding:18px 0;border-bottom:1px solid var(--rule);}
  @media (max-width:700px){.sayrow{grid-template-columns:1fr;gap:6px;}}
  .sayrow .cmd{font-family:var(--mono);font-size:15px;color:var(--ink);font-weight:500;}
  .sayrow .cmd::before{content:"\201C";color:var(--ink3);}.sayrow .cmd::after{content:"\201D";color:var(--ink3);}
  .sayrow .out{font-size:14.5px;color:var(--ink2);line-height:1.45;display:flex;align-items:baseline;gap:9px;}
  .sayrow .out b{color:var(--ink);font-weight:600;}
  .sayrow .out .d{width:7px;height:7px;border-radius:50%;flex-shrink:0;align-self:center;}

  /* ── states ribbon ── */
  .states{display:flex;gap:clamp(10px,2vw,24px);flex-wrap:wrap;align-items:flex-start;justify-content:center;border-radius:var(--corner);padding:34px 24px 30px;margin-top:0;
    background:radial-gradient(360px 220px at 50% 50%,rgba(230,59,46,.09),transparent 65%),repeating-linear-gradient(118deg,rgba(60,80,110,.05) 0 14px,transparent 14px 28px),linear-gradient(135deg,#c8d0da,#aeb9c6);box-shadow:var(--sh-lg);}
  .pc{display:flex;flex-direction:column;align-items:center;gap:11px;width:68px;}
  .pc .gd{width:40px;height:40px;border-radius:50% 50% 50% 8px;}
  .pc .pl{font-family:var(--mono);font-size:9px;letter-spacing:.12em;text-transform:uppercase;font-weight:600;text-align:center;}

  /* ── pillars ── */
  .pillars{margin-top:30px;border-top:1px solid var(--ink);}
  .pillar{display:grid;grid-template-columns:220px 1fr;gap:24px;align-items:baseline;padding:20px 0;border-bottom:1px solid var(--rule);}
  @media (max-width:700px){.pillar{grid-template-columns:1fr;gap:6px;}}
  .pillar .nm{font-size:19px;font-weight:700;letter-spacing:-.02em;}
  .pillar .d{font-size:14.5px;color:var(--ink2);line-height:1.5;}.pillar .d b{color:var(--ink);font-weight:600;}
</style>
<style is:inline>
  /* ── summoned room ── */
  .desk{position:relative;height:300px;border-radius:var(--corner);overflow:hidden;background:repeating-linear-gradient(118deg,rgba(60,80,110,.05) 0 15px,transparent 15px 30px),linear-gradient(155deg,#cdd4dd,#b5bec9);box-shadow:var(--sh-lg);}
  .desk .win{position:absolute;left:22px;top:22px;width:48%;height:120px;border-radius:11px;background:rgba(255,255,255,.55);box-shadow:inset 0 0 0 1px rgba(255,255,255,.5),0 12px 28px -16px rgba(20,30,45,.3);}
  .desk .win .l{height:7px;border-radius:4px;background:rgba(20,30,45,.1);margin:14px 18px}.desk .win .l.a{width:48%;margin-top:18px}.desk .win .l.b{width:64%}
  .desk .room{position:absolute;right:24px;top:40px;width:240px;border-radius:13px 4px 13px 13px;overflow:hidden;background:rgba(255,255,255,.55);-webkit-backdrop-filter:blur(16px) saturate(1.4);backdrop-filter:blur(16px) saturate(1.4);box-shadow:inset 0 1px 1px rgba(255,255,255,.6),0 18px 40px -16px rgba(20,30,45,.4);border:.5px solid rgba(255,255,255,.5);}
  .desk .room .rh{font-family:var(--mono);font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:#4a5560;padding:11px 13px;border-bottom:.5px solid rgba(20,30,45,.08);}
  .desk .room .ri{display:flex;align-items:center;justify-content:space-between;padding:9px 13px;font-size:12px;color:#2a323b;}
  .desk .room .ri .sw{width:26px;height:15px;border-radius:999px;background:#13161A;position:relative}.desk .room .ri .sw i{position:absolute;top:2px;right:2px;width:11px;height:11px;border-radius:50%;background:#fff}
  .desk .room .ri .sw.off{background:rgba(20,30,45,.18)}.desk .room .ri .sw.off i{right:auto;left:2px}
