---
import Landing from '../layouts/Landing.astro';
---

<Landing
  title="J.A.R.V.I.S. — The AI That Doesn't Ask Permission"
  description="An always-on autonomous AI daemon that browses the web, controls your desktop, manages your calendar, and executes tasks while you sleep."
>

  <!-- ============================================================
       NAVIGATION
  ============================================================ -->
  <nav
    style="
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(13, 17, 23, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 212, 255, 0.08);
    "
  >
    <div
      style="
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      "
    >
      <!-- Logo -->
      <a
        href="/"
        style="
          font-size: 1.125rem;
          font-weight: 800;
          letter-spacing: 0.12em;
          color: #00d4ff;
          text-decoration: none;
          text-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
        "
      >
        J.A.R.V.I.S.
      </a>

      <!-- Desktop links -->
      <div
        class="nav-links-desktop"
        style="
          display: flex;
          align-items: center;
          gap: 2rem;
        "
      >
        <a href="#features" class="nav-link">Features</a>
        <a href="/docs/introduction" class="nav-link">Docs</a>
        <a
          href="https://github.com/vierisid/jarvis"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link"
          style="display: flex; align-items: center; gap: 0.375rem;"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          GitHub
        </a>
        <a href="/docs/installation" class="btn-primary" style="padding: 0.5rem 1.25rem; font-size: 0.875rem;">
          Install
        </a>
      </div>
    </div>
  </nav>

  <!-- ============================================================
       HERO SECTION
  ============================================================ -->
  <section
    class="bg-grid"
    style="
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 8rem 1.5rem 6rem;
    "
  >
    <!-- Background radial glow -->
    <div class="hero-glow"></div>

    <!-- Ambient corner glows -->
    <div style="
      position: absolute;
      top: 0;
      right: 0;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle at top right, rgba(0, 212, 255, 0.04), transparent 70%);
      pointer-events: none;
    "></div>
    <div style="
      position: absolute;
      bottom: 0;
      left: 0;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle at bottom left, rgba(0, 212, 255, 0.03), transparent 70%);
      pointer-events: none;
    "></div>

    <div
      style="
        max-width: 1200px;
        width: 100%;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 4rem;
        flex-wrap: wrap;
      "
    >
      <!-- Text content -->
      <div style="flex: 1; min-width: 280px; max-width: 640px;">
        <!-- Status badge -->
        <div
          class="animate-fade-in"
          style="
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(0, 212, 255, 0.06);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 2rem;
            padding: 0.375rem 0.875rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: #00d4ff;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
          "
        >
          <span style="
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #00d4ff;
            display: inline-block;
            box-shadow: 0 0 6px #00d4ff;
            animation: corePulse 2s ease-in-out infinite;
          "></span>
          Autonomous AI Daemon — Always Online
        </div>

        <!-- Headline -->
        <h1
          class="animate-fade-in animate-delay-100"
          style="
            font-size: clamp(2.5rem, 6vw, 4rem);
            font-weight: 900;
            line-height: 1.08;
            color: #f0f6fc;
            margin: 0 0 1.5rem;
            letter-spacing: -0.02em;
          "
        >
          The AI That<br />
          <span style="
            color: #00d4ff;
            text-shadow: 0 0 30px rgba(0, 212, 255, 0.4);
          ">Doesn't Ask<br />Permission.</span>
        </h1>

        <!-- Subtext -->
        <p
          class="animate-fade-in animate-delay-200"
          style="
            font-size: 1.125rem;
            line-height: 1.7;
            color: #8b949e;
            margin: 0 0 2.5rem;
            max-width: 520px;
          "
        >
          An always-on autonomous daemon that browses the web, controls your desktop,
          manages your calendar, and executes tasks while you sleep.
        </p>

        <!-- CTAs -->
        <div
          class="animate-fade-in animate-delay-300"
          style="
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 2.5rem;
          "
        >
          <a href="/docs/installation" class="btn-primary">
            Get Started
          </a>
          <a
            href="https://github.com/vierisid/jarvis"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline"
            style="display: inline-flex; align-items: center; gap: 0.5rem;"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <!-- Install one-liner -->
        <div
          class="animate-fade-in animate-delay-400 code-block"
          style="max-width: 520px; display: flex; align-items: center; justify-content: space-between; gap: 1rem;"
        >
          <code style="overflow-x: auto; white-space: nowrap;">
            <span class="prompt">$</span> curl -fsSL https://raw.githubusercontent.com/vierisid/jarvis/main/install.sh | bash
          </code>
          <button
            onclick="navigator.clipboard.writeText('curl -fsSL https://raw.githubusercontent.com/vierisid/jarvis/main/install.sh | bash'); this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Copy', 2000);"
            style="
              background: rgba(0, 212, 255, 0.08);
              border: 1px solid rgba(0, 212, 255, 0.2);
              border-radius: 0.375rem;
              color: #00d4ff;
              font-size: 0.75rem;
              font-weight: 600;
              padding: 0.375rem 0.625rem;
              cursor: pointer;
              white-space: nowrap;
              transition: all 0.2s ease;
              font-family: inherit;
            "
            onmouseover="this.style.background='rgba(0,212,255,0.15)'"
            onmouseout="this.style.background='rgba(0,212,255,0.08)'"
          >
            Copy
          </button>
        </div>
      </div>

      <!-- Arc Reactor visual -->
      <div
        class="animate-fade-in animate-delay-300"
        style="
          flex-shrink: 0;
          display: flex;
          align-items: center;
          justify-content: center;
        "
      >
        <div class="arc-reactor">
          <div class="arc-ring arc-ring-1"></div>
          <div class="arc-ring arc-ring-2"></div>
          <div class="arc-ring arc-ring-3"></div>
          <div class="arc-ring arc-ring-4"></div>
          <div class="arc-core"></div>
          <div class="arc-scan"></div>

          <!-- Tick marks on outer ring -->
          {Array.from({ length: 12 }).map((_, i) => (
            <div style={`
              position: absolute;
              width: 8px;
              height: 1px;
              background: rgba(0, 212, 255, ${i % 3 === 0 ? '0.7' : '0.3'});
              top: 50%;
              left: 50%;
              transform-origin: left center;
              transform: rotate(${i * 30}deg) translateX(134px);
            `}></div>
          ))}
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      style="
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        color: #484f58;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      "
    >
      <span>Scroll</span>
      <div style="
        width: 1px;
        height: 32px;
        background: linear-gradient(to bottom, rgba(0, 212, 255, 0.4), transparent);
        animation: fadeInUp 2s ease infinite;
      "></div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ============================================================
       FEATURES GRID
  ============================================================ -->
  <section id="features" style="padding: 6rem 1.5rem; max-width: 1200px; margin: 0 auto;">
    <!-- Section header -->
    <div class="observe-fade" style="text-align: center; margin-bottom: 4rem;">
      <p style="
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #00d4ff;
        margin-bottom: 0.75rem;
      ">
        Capabilities
      </p>
      <h2 style="
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 800;
        color: #f0f6fc;
        margin: 0 0 1rem;
        letter-spacing: -0.02em;
      ">
        Everything Tony Stark Wished He Had
      </h2>
      <p style="
        font-size: 1.0625rem;
        color: #6e7681;
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.7;
      ">
        JARVIS operates across browser, desktop, voice, and communication channels
        — fully autonomous, fully integrated.
      </p>
    </div>

    <!-- Grid -->
    <div style="
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
    ">

      <!-- Feature: Browser Control -->
      <div class="feature-card observe-fade">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00d4ff" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
        </div>
        <h3 style="font-size: 1.0625rem; font-weight: 700; color: #f0f6fc; margin: 0 0 0.625rem; letter-spacing: -0.01em;">
          Browser Control
        </h3>
        <p style="font-size: 0.9rem; color: #6e7681; line-height: 1.65; margin: 0;">
          Full Chrome/Chromium automation via CDP. Browse, click, extract, fill forms
          — all autonomously. Stealth mode included.
        </p>
      </div>

      <!-- Feature: Desktop Control -->
      <div class="feature-card observe-fade">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00d4ff" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3 style="font-size: 1.0625rem; font-weight: 700; color: #f0f6fc; margin: 0 0 0.625rem; letter-spacing: -0.01em;">
          Desktop Control
        </h3>
        <p style="font-size: 0.9rem; color: #6e7681; line-height: 1.65; margin: 0;">
          Native Windows app control via FlaUI sidecar. Click buttons, read text,
          automate any desktop app — including legacy software.
        </p>
      </div>

      <!-- Feature: Voice Interface -->
      <div class="feature-card observe-fade">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00d4ff" stroke-width="1.5">
            <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
            <path d="M19 10v2a7 7 0 01-14 0v-2"/>
            <line x1="12" y1="19" x2="12" y2="23"/>
            <line x1="8" y1="23" x2="16" y2="23"/>
          </svg>
        </div>
        <h3 style="font-size: 1.0625rem; font-weight: 700; color: #f0f6fc; margin: 0 0 0.625rem; letter-spacing: -0.01em;">
          Voice Interface
        </h3>
        <p style="font-size: 0.9rem; color: #6e7681; line-height: 1.65; margin: 0;">
          Wake word detection, speech-to-text, and text-to-speech. Talk to JARVIS
          like Tony Stark — hands-free, always listening.
        </p>
      </div>

      <!-- Feature: Multi-Agent System -->
      <div class="feature-card observe-fade">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00d4ff" stroke-width="1.5">
            <circle cx="12" cy="5" r="3"/>
            <circle cx="5" cy="19" r="3"/>
            <circle cx="19" cy="19" r="3"/>
            <line x1="12" y1="8" x2="12" y2="14"/>
            <line x1="12" y1="14" x2="5" y2="16"/>
            <line x1="12" y1="14" x2="19" y2="16"/>
          </svg>
        </div>
        <h3 style="font-size: 1.0625rem; font-weight: 700; color: #f0f6fc; margin: 0 0 0.625rem; letter-spacing: -0.01em;">
          Multi-Agent System
        </h3>
        <p style="font-size: 0.9rem; color: #6e7681; line-height: 1.65; margin: 0;">
          Delegate tasks to specialist agents. Parallel execution, research teams,
          divide and conquer — 11 specialist roles available.
        </p>
      </div>

      <!-- Feature: Proactive Agent -->
      <div class="feature-card observe-fade">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00d4ff" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3 style="font-size: 1.0625rem; font-weight: 700; color: #f0f6fc; margin: 0 0 0.625rem; letter-spacing: -0.01em;">
          Proactive Agent
        </h3>
        <p style="font-size: 0.9rem; color: #6e7681; line-height: 1.65; margin: 0;">
          Commitments, scheduled tasks, email monitoring, calendar alerts.
          JARVIS works while you don't — 24/7, unattended.
        </p>
      </div>

      <!-- Feature: Memory & Knowledge -->
      <div class="feature-card observe-fade">
        <div class="feature-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00d4ff" stroke-width="1.5">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
          </svg>
        </div>
        <h3 style="font-size: 1.0625rem; font-weight: 700; color: #f0f6fc; margin: 0 0 0.625rem; letter-spacing: -0.01em;">
          Memory & Knowledge
        </h3>
        <p style="font-size: 0.9rem; color: #6e7681; line-height: 1.65; margin: 0;">
          Persistent knowledge vault with semantic search. JARVIS remembers
          everything across conversations — context always intact.
        </p>
      </div>
    </div>
  </section>

  <div class="section-divider" style="max-width: 1200px; margin: 0 auto;"></div>

  <!-- ============================================================
       INTEGRATIONS SECTION
  ============================================================ -->
  <section style="padding: 5rem 1.5rem; overflow: hidden;">
    <div class="observe-fade" style="text-align: center; margin-bottom: 3rem;">
      <p style="
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #00d4ff;
        margin-bottom: 0.75rem;
      ">
        Integrations
      </p>
      <h2 style="
        font-size: clamp(1.75rem, 3.5vw, 2.25rem);
        font-weight: 800;
        color: #f0f6fc;
        margin: 0;
        letter-spacing: -0.02em;
      ">
        Connected to Your Entire World
      </h2>
    </div>

    <!-- Scrolling badges row -->
    <div style="
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    ">

      <span class="integration-badge observe-fade">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#0088cc">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        Telegram
      </span>

      <span class="integration-badge observe-fade">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#5865F2">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
        </svg>
        Discord
      </span>

      <span class="integration-badge observe-fade">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#EA4335">
          <path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/>
        </svg>
        Gmail
      </span>

      <span class="integration-badge observe-fade">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#4285F4">
          <path d="M19.5 3h-15A1.5 1.5 0 003 4.5v15A1.5 1.5 0 004.5 21h15a1.5 1.5 0 001.5-1.5v-15A1.5 1.5 0 0019.5 3zM8 17H5v-7h3v7zm-1.5-8.268a1.732 1.732 0 110-3.464 1.732 1.732 0 010 3.464zM19 17h-3v-3.604c0-3.368-4-3.113-4 0V17h-3v-7h3v1.765C12.396 9.18 16 8.937 16 12.6V17z"/>
        </svg>
        Google Calendar
      </span>

      <span class="integration-badge observe-fade">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#4285F4">
          <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1 15v-4H7l5-8v4h4l-5 8z"/>
        </svg>
        Chrome / CDP
      </span>

      <span class="integration-badge observe-fade">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#0078D4">
