---
import Landing from '../layouts/Landing.astro';

// Seven pebble feature sections. Each gets a short on-page demo loop.
const features = [
  {
    id: 'pebble',
    label: 'The Pebble',
    title: 'A cursor companion.',
    body: 'Trails your cursor with eased physics. Click-through everywhere except the bubble. Five states — idle, listening, thinking, speaking, working.',
    poster: '/demos/posters/pebble.jpg',
    video: '/demos/pebble.mp4',
    flip: false,
  },
  {
    id: 'voice',
    label: 'Voice loop',
    title: 'Wake word — or ⌃Space.',
    body: 'Say "Jarvis" anywhere in a sentence. Streaming TTS replies in 1–2 seconds. Press the hotkey mid-speech and JARVIS shuts up in 10ms.',
    poster: '/demos/posters/voice.jpg',
    video: '/demos/voice.mp4',
    flip: true,
  },
  {
    id: 'rooms',
    label: '12 rooms by voice',
    title: 'Open. Navigate. Close.',
    body: '"Open settings." "Switch to the editor tab." "Close it." Each of the 12 rooms — settings, memory, agents, workflows, tools, authority, logs, calendar, goals, tasks, content, workspaces — opens as a native panel.',
    poster: '/demos/posters/rooms.jpg',
    video: '/demos/rooms.mp4',
    flip: false,
  },
  {
    id: 'settings',
    label: 'Settings by voice',
    title: 'Skip the LLM.',
    body: '"Turn off TTS." "Switch transcription to Groq." Recognized commands persist to disk and apply instantly — no LLM in the loop.',
    poster: '/demos/posters/settings.jpg',
    video: '/demos/settings.mp4',
    flip: true,
  },
  {
    id: 'autonomy',
    label: 'Autonomous',
    title: 'Acts before you ask.',
    body: 'Watches your screen, calendar, and goals. Drafts the brief for the meeting you forgot, queues the reply that needs to go out, surfaces the next move. Always optional.',
    poster: '/demos/posters/autonomy.jpg',
    video: '/demos/autonomy.mp4',
    flip: false,
  },
  {
    id: 'pointing',
    label: 'Pointing',
    title: '"Where do I click?"',
    body: 'Auto-screenshot, grid math, the pebble flies to the right button. Works in any app, foreground-aware — "show me my files" resolves differently in VSCode versus CapCut.',
    poster: '/demos/posters/pointing.jpg',
    video: '/demos/pointing.mp4',
    flip: true,
  },
  {
    id: 'region',
    label: 'Region understanding',
    title: '"What is this?"',
    body: 'Drag a rectangle on screen. JARVIS sees the cropped region through any vision-capable model and answers from what it sees.',
    poster: '/demos/posters/region.jpg',
    video: '/demos/region.mp4',
    flip: false,
  },
];
---

<Landing>
  <!-- ── NAV ──────────────────────────────────────── -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="nav-dot"></span>
        J.A.R.V.I.S.
      </a>
      <div class="nav-right">
        <a href="#trailer" class="nav-link">Watch</a>
        <a href="#pebble" class="nav-link">Pebble</a>
        <a href="#workflows" class="nav-link">Workflows</a>
        <a href="#sidecar" class="nav-link">Sidecar</a>
        <a href="/blog" class="nav-link">Blog</a>
        <a href="/roadmap" class="nav-link">Roadmap</a>
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="nav-link">GitHub</a>
        <a href="/docs/installation" class="btn-solid nav-cta">Install</a>
      </div>
    </div>
  </nav>

  <!-- ── HERO ─────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <p class="label-mono reveal reveal-up">Always-on · Voice-first · Open source</p>
      <h1 class="display-h1 hero-h1 reveal reveal-up">
        The first 24/7 AI agent OS<br/>
        <em>without</em> a dashboard
      </h1>
      <p class="lead hero-lead reveal reveal-up">
        A cursor companion. Say <em>"Jarvis"</em> or hit <kbd>⌃ Space</kbd>.
        Everything the dashboard does — <em>without ever opening it.</em>
      </p>
      <div class="hero-actions reveal reveal-up">
        <a href="/docs/installation" class="btn-solid">Get Started</a>
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="btn-border">View Source</a>
      </div>
      <div class="code-chip hero-cmd reveal reveal-up">
        <span class="code-prompt">$</span>
        <span><span class="code-pkg">bun install -g @usejarvis/brain</span></span>
      </div>
    </div>

    <!-- Static pebble + cursor illustration -->
    <div class="hero-illu reveal reveal-up">
      <div class="hero-illu-frame">
        <svg class="hero-cursor" viewBox="0 0 18 22" width="36" height="44" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 1l14 9-7 1 4 8-3 1-4-8-4 4z" fill="#fff" stroke="#1c1c1c" stroke-width="1" stroke-linejoin="round" />
        </svg>
        <span class="hero-pebble">
          <span class="hero-pebble-wave">
            <span></span><span></span><span></span><span></span>
          </span>
          <span class="hero-pebble-label">listening</span>
        </span>
      </div>
      <p class="hero-illu-cap">A cursor companion. Riso flat. Always-on-top.<br/>Click-through everywhere except the bubble.</p>
    </div>
  </section>

  <!-- ── TRAILER ──────────────────────────────────── -->
  <section id="trailer" class="trailer">
    <div class="section-inner">
      <p class="label-mono reveal reveal-up">90 seconds</p>
      <h2 class="display-h2 reveal reveal-up">See it. <em>In one Tuesday.</em></h2>
      <div class="trailer-frame reveal reveal-up">
        <video
          class="trailer-video"
          poster="/demos/posters/trailer.jpg"
          src="/demos/JarvisTrailer.mp4"
          controls
          playsinline
          preload="metadata"
        >
          Your browser doesn't support video. Watch on
          <a href="https://github.com/vierisid/jarvis">GitHub</a>.
        </video>
      </div>
    </div>
  </section>

  <!-- ── PEBBLE FEATURES ──────────────────────────── -->
  <section id="pebble" class="features">
    <div class="features-inner">
      <p class="label-mono reveal reveal-up" style="text-align: center; margin-bottom: 12px;">
        Seven things the pebble does
      </p>
      <h2 class="display-h2 features-heading reveal reveal-up">
        Everything the dashboard does.<br/>
        <em>By voice. From your cursor.</em>
      </h2>

      {features.map((f, i) => (
        <article class={`feature ${f.flip ? 'feature-flip' : ''}`} id={f.id}>
          <div class="feature-copy">
            <p class="label-mono reveal reveal-up">{`0${i + 1} · ${f.label}`}</p>
            <h3 class="feature-title reveal reveal-up">{f.title}</h3>
            <p class="feature-body reveal reveal-up">{f.body}</p>
          </div>
          <div class="feature-media reveal reveal-up">
            <div class="mockup feature-mockup">
              <video
                class="feature-video"
                poster={f.poster}
                src={f.video}
                muted
                loop
                playsinline
                preload="none"
                data-lazy
              ></video>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ── RUNTIME (compressed) ─────────────────────── -->
  <section id="runtime" class="runtime">
    <div class="section-inner">
      <p class="label-mono reveal reveal-up">Underneath the pebble</p>
      <h2 class="display-h2 reveal reveal-up">A real <em>runtime.</em> Not a chat wrapper.</h2>

      <div class="runtime-strip reveal reveal-up">
        <div class="runtime-cell">
          <span class="runtime-num">Memory</span>
          <span class="runtime-meta">Knowledge graph · entity vault · semantic recall</span>
        </div>
        <div class="runtime-cell">
          <span class="runtime-num">Awareness</span>
          <span class="runtime-meta">Continuous OCR · activity tracking · struggle detection</span>
        </div>
        <div class="runtime-cell">
          <span class="runtime-num">Action</span>
          <span class="runtime-meta">Browser via CDP · native desktop · terminal · voice TTS/STT</span>
        </div>
        <div class="runtime-cell">
          <span class="runtime-num">Orchestration</span>
          <span class="runtime-meta">11 agent roles · 50+ workflow nodes · OKR goal pursuit</span>
        </div>
        <div class="runtime-cell">
          <span class="runtime-num">Sidecar</span>
          <span class="runtime-meta">One brain · every machine · JWT-auth WebSocket</span>
        </div>
        <div class="runtime-cell">
          <span class="runtime-num">Authority</span>
          <span class="runtime-meta">Soft-gate approvals · audit trail · emergency stop</span>
        </div>
      </div>

      <div class="runtime-cta reveal reveal-up">
        <a href="/docs/introduction" class="btn-border">Read the architecture</a>
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="btn-border">Browse the source</a>
      </div>
    </div>
  </section>

  <!-- ── WORKFLOWS ────────────────────────────────── -->
  <section id="workflows" class="callout">
    <div class="section-inner callout-inner">
      <div class="callout-copy">
        <p class="label-mono reveal reveal-up">Workflows</p>
        <h2 class="display-h2 reveal reveal-up">
          Compose with a sentence.<br/>
          <em>Or 50+ nodes.</em>
        </h2>
        <p class="lead reveal reveal-up">
          Describe what you want — <em>"every weekday at 8am, summarise yesterday's
          email and drop it in Telegram"</em> — and JARVIS generates the flow.
          Tune it visually if you need to. Triggers from cron, webhooks, file
          watchers, calendar, git, or screen events.
        </p>
        <ul class="callout-bullets reveal reveal-up">
          <li><span class="dot dot-accent"></span> NL composition · visual editor · YAML import</li>
          <li><span class="dot dot-accent"></span> Triggers: cron · webhook · file · screen · email · git</li>
          <li><span class="dot dot-accent"></span> Loops, routers, code nodes, sub-agents, ask-the-user</li>
          <li><span class="dot dot-accent"></span> Self-healing retries · audit log · sandboxed JS engine</li>
        </ul>
        <div class="callout-actions reveal reveal-up">
          <a href="/docs/workflows" class="btn-border">Read the workflows guide</a>
        </div>
      </div>

      <div class="callout-media reveal reveal-up">
        <div class="flow-card">
          <div class="flow-card-bar">
            <span class="flow-card-label">inbox-triage.flow</span>
            <span class="flow-card-status"><span class="dot dot-ok dot-pulse"></span> live</span>
          </div>
          <div class="flow-card-body">
            <div class="flow-node flow-node-trigger">
              <span class="flow-node-tag">trigger</span>
              <span class="flow-node-name">new email · gmail</span>
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-node">
              <span class="flow-node-tag">action</span>
              <span class="flow-node-name">classify with vision</span>
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-branch">
              <div class="flow-node flow-node-half">
                <span class="flow-node-tag">draft</span>
                <span class="flow-node-name">reply · gpt-4o</span>
              </div>
              <div class="flow-node flow-node-half">
                <span class="flow-node-tag">notify</span>
                <span class="flow-node-name">slack · #triage</span>
              </div>
            </div>
            <div class="flow-arrow">↓</div>
            <div class="flow-node flow-node-end">
              <span class="flow-node-tag">ask</span>
              <span class="flow-node-name">approve? — y/n via pebble</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SIDECAR / ONE BRAIN, MANY MACHINES ──────── -->
  <section id="sidecar" class="callout callout-alt">
    <div class="section-inner callout-inner callout-inner-flip">
      <div class="callout-media reveal reveal-up">
        <div class="sidecar-card">
          <div class="sidecar-brain">
            <span class="sidecar-dot sidecar-dot-brain"></span>
            <span class="sidecar-brain-label">brain</span>
            <span class="sidecar-brain-meta">192.168.1.20:3142</span>
          </div>
          <div class="sidecar-lines" aria-hidden="true">
            <svg viewBox="0 0 320 100" preserveAspectRatio="none">
              <path d="M160 0 L 60 100" />
              <path d="M160 0 L 160 100" />
              <path d="M160 0 L 260 100" />
            </svg>
          </div>
          <div class="sidecar-clients">
            <div class="sidecar-client">
              <span class="sidecar-dot"></span>
              <span class="sidecar-client-name">laptop · macOS</span>
              <span class="sidecar-client-meta">terminal · browser · screen</span>
            </div>
            <div class="sidecar-client">
              <span class="sidecar-dot"></span>
              <span class="sidecar-client-name">studio · Windows</span>
              <span class="sidecar-client-meta">desktop · clipboard</span>
            </div>
            <div class="sidecar-client">
              <span class="sidecar-dot"></span>
              <span class="sidecar-client-name">homelab · Linux</span>
              <span class="sidecar-client-meta">fs · long-running jobs</span>
            </div>
          </div>
          <div class="sidecar-protocol">
            <span class="label-mono">JWT · WebSocket · TLS 1.3</span>
          </div>
        </div>
      </div>

      <div class="callout-copy">
        <p class="label-mono reveal reveal-up">Sidecar</p>
        <h2 class="display-h2 reveal reveal-up">
          One brain.<br/>
          <em>Every machine.</em>
        </h2>
        <p class="lead reveal reveal-up">
          Run the brain once — on a homelab, a desktop, anywhere. A 6&nbsp;MB Go
          binary on each laptop, server, or Raspberry&nbsp;Pi connects back over
          a JWT-authenticated WebSocket. The pebble follows you to whichever
          machine you're using; JARVIS sees, types, and clicks on all of them.
        </p>
        <ul class="callout-bullets reveal reveal-up">
          <li><span class="dot dot-accent"></span> macOS · Linux · Windows · ARM — one binary each</li>
          <li><span class="dot dot-accent"></span> Per-machine toggles: terminal · browser · desktop · fs · clipboard</li>
          <li><span class="dot dot-accent"></span> Outbound-only — sidecars dial the brain, not the other way</li>
          <li><span class="dot dot-accent"></span> Detach &amp; reconnect — long jobs survive WiFi drops</li>
        </ul>
        <div class="code-chip reveal reveal-up callout-cmd">
          <span class="code-prompt">$</span>
          <span><span class="code-pkg">jarvis-sidecar --token &lt;jwt&gt;</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SETUP / FOOTER CTA ───────────────────────── -->
  <section class="setup">
    <div class="section-inner setup-inner">
      <h2 class="display-h2 reveal reveal-up">Three commands. <em>Then it lives with you.</em></h2>

      <div class="terminal reveal reveal-up">
        <div class="terminal-bar">
          <span class="tl tl-r"></span>
          <span class="tl tl-y"></span>
          <span class="tl tl-g"></span>
          <span class="terminal-label">bash</span>
        </div>
        <div class="terminal-body">
          <div><span class="t-comment"># 1. Install</span></div>
          <div><span class="t-prompt">$</span> <span class="t-cmd">bun install -g @usejarvis/brain</span></div>
          <br/>
          <div><span class="t-comment"># 2. Configure</span></div>
          <div><span class="t-prompt">$</span> <span class="t-cmd">jarvis onboard</span></div>
          <div><span class="t-ok">✓ LLM configured · ✓ Browser found · ✓ Sidecar built</span></div>
          <br/>
          <div><span class="t-comment"># 3. Launch</span></div>
          <div><span class="t-prompt">$</span> <span class="t-cmd">jarvis start</span></div>
          <div><span class="t-ok">✓ JARVIS runtime started (PID 4821)</span></div>
          <div><span class="t-comment">  Pebble visible at the bottom of your screen.</span></div>
        </div>
      </div>

      <div class="cta reveal reveal-up">
        <h3 class="cta-line">Your runtime. Your machine. Your agents.</h3>
        <p class="cta-sub">Open source. Self-hosted. Bring your own LLM.</p>
        <div class="cta-actions">
          <a href="/docs/installation" class="btn-solid">Read the Docs</a>
          <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="btn-border">Star on GitHub</a>
          <a href="https://discord.gg/C8fUM33mc" target="_blank" rel="noopener" class="btn-border">Discord</a>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="nav-dot"></span>
        <span class="footer-logo">J.A.R.V.I.S.</span>
        <span class="footer-copy">© 2026</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener">GitHub</a>
        <a href="/docs/introduction">Docs</a>
        <a href="/blog">Blog</a>
        <a href="/roadmap">Roadmap</a>
        <a href="https://discord.gg/C8fUM33mc" target="_blank" rel="noopener">Discord</a>
        <a href="/docs/disclaimer">Disclaimer</a>
      </div>
    </div>
    <p class="footer-disclaimer">
      JARVIS is an open-source runtime for autonomous AI agents, provided "as is" with no warranty.
      Agents running on JARVIS can autonomously control your browser, desktop, and external accounts.
      You assume all risk. See the full <a href="/docs/disclaimer">disclaimer</a>.
    </p>
  </footer>
</Landing>

<style>
  /* ── Nav ──────────────────────────────────── */
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(245, 242, 235, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: var(--hair);
  }
  .nav-inner {
    max-width: var(--col-wide);
    margin: 0 auto;
    padding: 0 28px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.08em;
  }
  .nav-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 4px rgba(194, 58, 42, 0.18);
    display: inline-block;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav-link {
    color: var(--ink-2);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav-link:hover { color: var(--accent); }
  .nav-cta {
    padding: 8px 16px;
    font-size: 13px;
  }

  @media (max-width: 880px) {
    .nav-right .nav-link:not(:nth-last-child(-n+2)) { display: none; }
  }

  /* ── Hero ─────────────────────────────────── */
  .hero {
    max-width: var(--col-wide);
    margin: 0 auto;
    padding: 96px 28px 72px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .hero-h1 {
    margin-top: 16px;
    margin-bottom: 24px;
  }
  .hero-lead { margin: 0 0 32px; }
  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .hero-cmd { max-width: 380px; }

  .hero-illu {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
    padding: 56px 40px;
    border: var(--hair);
    background: var(--paper);
    border-radius: var(--r-2);
    box-shadow: 4px 4px 0 0 rgba(26, 26, 26, 0.06);
    background-image:
      linear-gradient(var(--rule-soft) 1px, transparent 1px),
      linear-gradient(90deg, var(--rule-soft) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .hero-illu-frame {
    position: relative;
    width: 220px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-cursor {
    position: absolute;
    left: 60px;
    top: 12px;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.45));
  }
  .hero-pebble {
    position: absolute;
    left: 100px;
    top: 50px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--paper-2);
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 0 12px 0 10px;
    height: 28px;
    box-shadow: 2px 2px 0 0 var(--accent);
  }
  .hero-pebble-wave {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    height: 14px;
  }
  .hero-pebble-wave span {
    width: 2px;
    background: var(--accent);
    border-radius: 0;
    animation: hero-wave 0.95s ease-in-out infinite;
    transform-origin: center;
  }
  .hero-pebble-wave span:nth-child(1) { height: 4px; animation-delay: 0s; }
  .hero-pebble-wave span:nth-child(2) { height: 10px; animation-delay: 0.09s; }
  .hero-pebble-wave span:nth-child(3) { height: 5px; animation-delay: 0.18s; }
  .hero-pebble-wave span:nth-child(4) { height: 12px; animation-delay: 0.27s; }
  @keyframes hero-wave {
    0%, 100% { transform: scaleY(0.6); }
    50% { transform: scaleY(1.2); }
  }
  .hero-pebble-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .hero-illu-cap {
    margin: 0;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.7;
    color: var(--ink-3);
    letter-spacing: 0.08em;
  }
  .hero-lead em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--accent);
  }
  .hero-lead kbd {
    font-family: var(--font-mono);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-bottom-width: 2px;
    border-radius: 2px;
    padding: 1px 6px;
    font-size: 13px;
    color: var(--ink);
    margin: 0 1px;
  }

  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; gap: 40px; padding: 64px 22px 48px; }
  }

  /* ── Section common ───────────────────────── */
  .section-inner {
    max-width: var(--col-wide);
    margin: 0 auto;
    padding: 96px 28px;
  }

  /* ── Trailer ──────────────────────────────── */
  .trailer {
    border-top: var(--hair);
    background: var(--paper);
  }
  .trailer-frame {
    margin-top: 40px;
    background: var(--paper-2);
    border: var(--hair);
