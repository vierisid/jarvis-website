---
import Landing from '../layouts/Landing.astro';
---

<Landing>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <div class="nav-left">
        <a href="/" class="nav-logo">J.A.R.V.I.S.</a>
        <span class="nav-version">v0.1.0</span>
      </div>
      <div class="nav-right">
        <a href="#capabilities" class="nav-link">Features</a>
        <a href="#workflows" class="nav-link">Workflows</a>
        <a href="#goals" class="nav-link">Goals</a>
        <a href="/docs/introduction" class="nav-link">Docs</a>
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="nav-link">GitHub</a>
        <a href="/docs/installation" class="nav-install">INSTALL</a>
      </div>
    </div>
  </nav>
  <div class="scroll-progress" id="scrollProgress"></div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid">

      <!-- Left: copy -->
      <div>
        <p class="label">Always-on autonomous daemon</p>

        <h1 class="hero-heading">
          The AI that<br/>operates, not<br/>assists.
        </h1>

        <p class="hero-sub">
          Browser control. Desktop automation. Voice interface. Continuous screen awareness.
          Workflow automation. Autonomous goal pursuit. Multi-agent delegation. Runs 24/7 in the background on your machine. Self-hosted. Open source.
        </p>

        <div class="hero-actions">
          <a href="/docs/installation" class="btn-solid">Get Started</a>
          <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="btn-border">View Source</a>
        </div>

        <!-- Install command -->
        <div class="cmd-block">
          <code><span class="cmd-prompt">$</span> curl -fsSL <span class="cmd-highlight">https://...install.sh</span> | bash</code>
          <button class="cmd-copy" id="copy-btn">copy</button>
        </div>
      </div>

      <!-- Right: system status panel -->
      <div class="status-panel">
        <div class="status-header">
          <div class="status-header-left">
            <span class="dot dot-green dot-pulse"></span>
            <span class="status-title">System Status</span>
          </div>
          <span class="status-time" id="clock">--:--:-- UTC</span>
        </div>

        <div class="status-body">
          <div class="status-row">
            <span class="status-label">daemon</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">online</span></span>
            <span class="status-meta">pid 4821 · port 3142</span>
          </div>
          <div class="status-row">
            <span class="status-label">browser</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">ready</span></span>
            <span class="status-meta">chromium 121 · cdp:9222</span>
          </div>
          <div class="status-row">
            <span class="status-label">sidecar</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">active</span></span>
            <span class="status-meta">.NET 8 · tcp:9224</span>
          </div>
          <div class="status-row">
            <span class="status-label">voice</span>
            <span class="status-value"><span class="dot dot-cyan"></span><span class="status-cyan">listening</span></span>
            <span class="status-meta">wake-word · tts:edge</span>
          </div>
          <div class="status-row">
            <span class="status-label">agents</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">11 roles</span></span>
            <span class="status-meta">0 active · 0 queued</span>
          </div>
          <div class="status-row">
            <span class="status-label">memory</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">847 facts</span></span>
            <span class="status-meta">12 entities · sqlite</span>
          </div>
          <div class="status-row">
            <span class="status-label">awareness</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">active</span></span>
            <span class="status-meta">ocr + vision · 7s cycle</span>
          </div>
          <div class="status-row">
            <span class="status-label">workflows</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">4 active</span></span>
            <span class="status-meta">2 cron · 1 webhook · 1 screen</span>
          </div>
          <div class="status-row status-row-last">
            <span class="status-label">goals</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">3 active</span></span>
            <span class="status-meta">1 objective · 2 key results</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES STRIP — Compact, hover-expand -->
  <section id="capabilities" class="cap-strip">
    <div class="cap-strip-inner">
      <p class="cap-strip-label reveal reveal-up">Core Engine</p>
      <div class="cap-grid reveal reveal-up">
        <div class="cap-item">
          <div class="cap-dot-wrap"><span class="dot dot-green"></span></div>
          <div class="cap-name">Browser</div>
          <div class="cap-one">CDP automation</div>
          <div class="cap-detail">Navigate, click, fill, extract, screenshot. Stealth mode bypasses bot detection. Auto-launches with isolated profile.</div>
        </div>
        <div class="cap-item">
          <div class="cap-dot-wrap"><span class="dot dot-green"></span></div>
          <div class="cap-name">Desktop</div>
          <div class="cap-one">FlaUI sidecar</div>
          <div class="cap-detail">Native Windows app control via .NET 8 sidecar. Any button, any text field, any app. Multi-monitor support.</div>
        </div>
        <div class="cap-item">
          <div class="cap-dot-wrap"><span class="dot dot-cyan"></span></div>
          <div class="cap-name">Voice</div>
          <div class="cap-one">Wake word + TTS</div>
          <div class="cap-detail">"Hey JARVIS" ONNX detection. OpenAI Whisper STT. Edge TTS streaming. Binary WebSocket protocol.</div>
        </div>
        <div class="cap-item">
          <div class="cap-dot-wrap"><span class="dot dot-green"></span></div>
          <div class="cap-name">Awareness</div>
          <div class="cap-one">Screen OCR 7s</div>
          <div class="cap-detail">Captures screen with OCR every 7 seconds. Detects struggles. Escalates to cloud vision for app-specific help.</div>
        </div>
        <div class="cap-item">
          <div class="cap-dot-wrap"><span class="dot dot-amber"></span></div>
          <div class="cap-name">Agents</div>
          <div class="cap-one">11 roles</div>
          <div class="cap-detail">Parallel multi-agent delegation. Researcher, coder, writer, analyst, sysadmin, and more. Each has its own tool loop.</div>
        </div>
        <div class="cap-item">
          <div class="cap-dot-wrap"><span class="dot dot-green"></span></div>
          <div class="cap-name">Memory</div>
          <div class="cap-one">SQLite vault</div>
          <div class="cap-detail">Persistent facts, entities, relationships. Auto-extraction after every conversation. Semantic search context injection.</div>
        </div>
        <div class="cap-item">
          <div class="cap-dot-wrap"><span class="dot dot-green"></span></div>
          <div class="cap-name">Proactive</div>
          <div class="cap-one">Commitments</div>
          <div class="cap-detail">Gmail and Calendar observers. D-Bus notifications. Commitment executor. JARVIS keeps promises autonomously.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WORKFLOW SPOTLIGHT — Cinematic -->
  <section id="workflows" class="spotlight spotlight-wf">
    <div class="spotlight-inner">
      <div class="spot-grid">
        <div>
          <div class="spot-badge reveal reveal-left">NEW</div>
          <h2 class="spot-heading reveal reveal-left">Your AI builds its<br/>own automations.</h2>
          <p class="spot-sub reveal reveal-left">
            Describe what you want in plain English — or drag-and-drop in a visual canvas.
            50+ nodes. Every trigger type. Self-healing execution. Built into the daemon, not bolted on.
          </p>

          <div class="wf-canvas-mock reveal reveal-scale" id="wfCanvas">
            <div class="wf-canvas-header">
              <div class="wf-canvas-dots">
                <div class="td td-red"></div>
                <div class="td td-yellow"></div>
                <div class="td td-green"></div>
              </div>
              <span class="wf-canvas-label">Workflow Canvas</span>
            </div>
            <div class="wf-canvas-body">
              <div class="wf-node" style="top: 24px; left: 20px;" data-delay="0">
                <div class="wf-node-dot" style="background: #3ecf8e;"></div>
                <span>Cron · 9am daily</span>
              </div>
              <div class="wf-edge wf-edge-1" data-delay="200"></div>
              <div class="wf-node" style="top: 24px; left: 220px;" data-delay="150">
                <div class="wf-node-dot" style="background: #22d3ee;"></div>
                <span>Agent: Summarize PRs</span>
              </div>
              <div class="wf-edge wf-edge-2" data-delay="400"></div>
              <div class="wf-node" style="top: 24px; left: 440px;" data-delay="300">
                <div class="wf-node-dot" style="background: #e5a522;"></div>
                <span>If urgent</span>
              </div>
              <div class="wf-edge wf-edge-3a" data-delay="500"></div>
              <div class="wf-edge wf-edge-3b" data-delay="500"></div>
              <div class="wf-node" style="top: -16px; left: 610px;" data-delay="450">
                <div class="wf-node-dot" style="background: #ef4444;"></div>
                <span>Telegram alert</span>
              </div>
              <div class="wf-node" style="top: 64px; left: 610px;" data-delay="500">
                <div class="wf-node-dot" style="background: #22d3ee;"></div>
                <span>Slack summary</span>
              </div>
            </div>
          </div>
        </div>

        <div>
          <div class="code-panel reveal reveal-right">
            <div class="code-comment"># Create via chat — just tell JARVIS</div>
            <div><span class="code-str">"Every morning at 9, check GitHub PRs.</span></div>
            <div><span class="code-str"> If anything is urgent, Telegram me.</span></div>
            <div><span class="code-str"> Otherwise, post a summary to Slack."</span></div>
            <br/>
            <div><span class="code-fn">Workflow created</span> <span class="code-str">· 5 nodes · 4 edges</span></div>
            <div><span class="code-fn2">Triggers active</span> <span class="code-str">· cron: 0 9 * * *</span></div>
          </div>
          <div class="code-panel reveal reveal-right" style="margin-top: 1rem;">
            <div class="code-comment"># Self-healing execution</div>
            <div><span class="code-fn2">step 1</span> <span class="code-fn">passed</span> <span class="code-str">trigger.cron</span></div>
            <div><span class="code-fn2">step 2</span> <span class="code-fn">passed</span> <span class="code-str">action.agent_task</span></div>
            <div><span class="code-fn2">step 3</span> <span class="status-amber">failed</span> <span class="code-str">action.http_request</span></div>
            <div><span class="code-fn2">       </span> <span class="code-fn">self-heal</span> <span class="code-str">&rarr; fixed auth header</span></div>
            <div><span class="code-fn2">step 3</span> <span class="code-fn">passed</span> <span class="code-str">action.http_request (retry)</span></div>
            <div><span class="code-fn2">step 4</span> <span class="code-fn">passed</span> <span class="code-str">action.notification</span></div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="spot-stats reveal reveal-up">
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="11">0</span>
          <span class="spot-stat-label">Triggers</span>
          <span class="spot-stat-detail">cron, webhook, file, screen, git, email, calendar, clipboard, process, poll, manual</span>
        </div>
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="12">0</span>
          <span class="spot-stat-label">Actions</span>
          <span class="spot-stat-detail">HTTP, agent task, shell, code, Gmail, Telegram, Discord, notification, file write, run tool</span>
        </div>
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="9">0</span>
          <span class="spot-stat-label">Logic</span>
          <span class="spot-stat-detail">if/else, switch, loop, delay, merge, race, variable set/get, template render</span>
        </div>
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="8">0</span>
          <span class="spot-stat-label">Transform + Error</span>
          <span class="spot-stat-detail">JSON, CSV, regex, aggregate, map/filter, error handler, retry, fallback</span>
        </div>
      </div>

      <div class="spot-cta reveal reveal-up">
        <a href="/docs/workflows" class="btn-solid">Explore Workflows</a>
        <a href="/docs/workflows#api-reference" class="btn-border">API Reference</a>
      </div>
    </div>
  </section>

  <!-- GOALS SPOTLIGHT — Different layout: centered header, tree left, code right -->
  <section id="goals" class="spotlight spotlight-gl">
    <div class="spotlight-inner">
      <div class="spot-header-center">
        <div class="spot-badge spot-badge-amber reveal reveal-up">NEW</div>
        <h2 class="spot-heading reveal reveal-up">Your AI has ambitions now.</h2>
        <p class="spot-sub reveal reveal-up" style="max-width: 620px; margin: 0 auto;">
          OKR-style goal hierarchy with drill-sergeant accountability. JARVIS decomposes objectives into daily actions,
          tracks progress from your screen activity, and escalates when you fall behind. Morning planning. Evening review. No mercy.
        </p>
      </div>

      <div class="spot-grid spot-grid-gl">
        <!-- Left: Goal tree (slides in from left) -->
        <div class="reveal reveal-left">
          <div class="gl-tree">
            <div class="gl-tree-node gl-tree-obj">
              <span class="gl-tree-dot" style="background: var(--accent);"></span>
              <span class="gl-tree-label">Get fit by summer</span>
              <span class="gl-tree-score gl-score-good">0.45</span>
            </div>
            <div class="gl-tree-branch"></div>
            <div class="gl-tree-children">
              <div class="gl-tree-node">
                <span class="gl-tree-dot" style="background: var(--accent-cyan);"></span>
                <span class="gl-tree-label">Run 5K under 25min</span>
                <span class="gl-tree-score gl-score-warn">0.30</span>
              </div>
              <div class="gl-tree-node">
                <span class="gl-tree-dot" style="background: var(--accent-cyan);"></span>
                <span class="gl-tree-label">Lose 10 lbs</span>
                <span class="gl-tree-score gl-score-good">0.60</span>
              </div>
              <div class="gl-tree-branch gl-tree-branch-deep"></div>
              <div class="gl-tree-grandchildren">
                <div class="gl-tree-node gl-tree-daily">
                  <span class="gl-tree-dot" style="background: var(--accent-amber);"></span>
                  <span class="gl-tree-label">Morning run</span>
                  <span class="gl-tree-tag">daily</span>
                </div>
                <div class="gl-tree-node gl-tree-daily">
                  <span class="gl-tree-dot" style="background: var(--accent-amber);"></span>
                  <span class="gl-tree-label">Track calories</span>
                  <span class="gl-tree-tag">daily</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Code panels (slide in from right) -->
        <div>
          <div class="code-panel reveal reveal-right">
            <div class="code-comment"># Just tell JARVIS your goal</div>
            <div><span class="code-str">"I want to get fit by summer"</span></div>
            <br/>
            <div><span class="code-fn">Proposed OKR breakdown:</span></div>
            <div><span class="code-fn2">  objective</span> <span class="code-str">Get fit by summer</span></div>
            <div><span class="code-fn2">  key_result</span> <span class="code-str">Run 5K under 25min</span></div>
            <div><span class="code-fn2">  key_result</span> <span class="code-str">Lose 10 lbs</span></div>
            <div><span class="code-fn2">  daily_action</span> <span class="code-str">Morning run · Track calories</span></div>
          </div>
          <div class="code-panel reveal reveal-right" style="margin-top: 1rem;">
            <div class="code-comment"># Drill sergeant doesn't sugarcoat</div>
            <div><span class="status-amber">07:00</span> <span class="code-str">Morning plan generated</span></div>
            <div><span class="code-fn2">  focus:</span> <span class="code-str">"Run 5K" is behind pace (0.30/1.0)</span></div>
            <div><span class="code-fn2">  action:</span> <span class="code-str">30min run scheduled at 6:30am</span></div>
            <br/>
            <div><span class="status-amber">21:00</span> <span class="code-str">Evening review</span></div>
            <div><span class="code-fn">  +0.05</span> <span class="code-str">Auto-detected: ran 3.2K via Strava</span></div>
            <div class="code-warn">  MISSED: No calorie tracking today</div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="spot-stats reveal reveal-up">
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="5">0</span>
          <span class="spot-stat-label">Goal Levels</span>
          <span class="spot-stat-detail">objective, key result, milestone, task, daily action</span>
        </div>
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="0.7" data-decimal="true">0</span>
          <span class="spot-stat-label">= Good Score</span>
          <span class="spot-stat-detail">Google OKR scoring: 0.7 is on track, 1.0 means you aimed too low</span>
        </div>
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="2">0</span>
          <span class="spot-stat-label">Daily Rhythm</span>
          <span class="spot-stat-detail">morning plan + evening review, automated with drill sergeant tone</span>
        </div>
        <div class="spot-stat">
          <span class="spot-stat-num" data-count="4">0</span>
          <span class="spot-stat-label">Escalation Stages</span>
          <span class="spot-stat-detail">none &rarr; pressure &rarr; root cause &rarr; suggest kill</span>
        </div>
      </div>

      <div class="spot-cta reveal reveal-up">
        <a href="/docs/goals" class="btn-solid">Explore Goals</a>
        <a href="/docs/goals#api-reference" class="btn-border">API Reference</a>
      </div>
    </div>
  </section>

  <!-- SETUP + CTA — Merged -->
  <section class="setup-section">
    <div class="setup-inner">
      <div class="terminal reveal reveal-up">
        <div class="terminal-header">
          <div class="terminal-dots">
            <div class="td td-red"></div>
            <div class="td td-yellow"></div>
            <div class="td td-green"></div>
          </div>
          <span class="terminal-label">bash</span>
        </div>
        <div class="terminal-body">
          <div class="code-comment"># 1. Install</div>
          <div><span class="code-comment">$</span> <span class="cmd-highlight">curl -fsSL https://raw.githubusercontent.com/vierisid/jarvis/main/install.sh | bash</span></div>
          <br/>
          <div class="code-comment"># 2. Configure</div>
          <div><span class="code-comment">$</span> <span class="cmd-highlight">jarvis onboard</span></div>
          <div class="code-fn"> ✓ LLM configured · ✓ Browser found · ✓ Sidecar built</div>
          <br/>
          <div class="code-comment"># 3. Launch</div>
          <div><span class="code-comment">$</span> <span class="cmd-highlight">jarvis start</span></div>
          <div class="code-fn"> ✓ JARVIS daemon started (PID 4821)</div>
          <div class="code-comment">   Dashboard: http://localhost:3142</div>
        </div>
      </div>

      <div class="channel-row reveal reveal-up">
        <p class="channel-label">Reachable on</p>
        <div class="channel-pills">
          <span class="channel-pill"><span class="dot dot-green"></span> Dashboard <span class="channel-meta">:3142</span></span>
          <span class="channel-pill"><span class="dot dot-green"></span> Telegram</span>
          <span class="channel-pill"><span class="dot dot-green"></span> Discord</span>
          <span class="channel-pill"><span class="dot dot-green"></span> Gmail</span>
          <span class="channel-pill"><span class="dot dot-green"></span> Calendar</span>
        </div>
      </div>

      <div class="cta reveal reveal-up">
        <h2 class="cta-heading">Deploy your own JARVIS.</h2>
        <p class="cta-sub">Open source. Self-hosted. No subscriptions. Full ownership of your AI.</p>
        <div class="cta-actions">
          <a href="/docs/installation" class="btn-solid">Read the Docs</a>
          <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="btn-border">Star on GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="footer-logo">J.A.R.V.I.S.</span>
        <span class="footer-copy">&copy; 2026</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener">GitHub</a>
        <a href="/docs/introduction">Docs</a>
        <a href="https://discord.gg/jarvis-ai" target="_blank" rel="noopener">Discord</a>
        <a href="/docs/disclaimer">Disclaimer</a>
      </div>
    </div>
    <div class="footer-disclaimer">
      JARVIS is experimental software provided "as is" with no warranty. It can autonomously control your browser, desktop, and external accounts. You assume all risk. See the full <a href="/docs/disclaimer">disclaimer</a>.
    </div>
  </footer>

</Landing>

<style>
  /* ── Nav ──────────────────────────────────── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1120px; margin: 0 auto; padding: 0 1.5rem;
    height: 56px; display: flex; align-items: center; justify-content: space-between;
  }
  .nav-left { display: flex; align-items: center; gap: 0.75rem; }
  .nav-logo {
    font-family: var(--mono); font-size: 0.875rem; font-weight: 700;
    color: var(--text-primary); text-decoration: none; letter-spacing: 0.08em;
  }
  .nav-version {
    font-family: var(--mono); font-size: 0.6875rem;
    color: var(--text-muted); font-weight: 500;
  }
  .nav-right { display: flex; align-items: center; gap: 1.75rem; }
  .nav-link {
    color: var(--text-secondary); text-decoration: none;
    font-size: 0.8125rem; font-weight: 500; transition: color 0.15s;
  }
  .nav-link:hover { color: var(--text-primary); }
  .nav-install {
    font-family: var(--mono); font-size: 0.75rem; font-weight: 600;
    color: var(--bg); background: var(--text-primary);
    padding: 0.375rem 0.875rem; border-radius: 4px;
    text-decoration: none; transition: opacity 0.15s;
  }
  .nav-install:hover { opacity: 0.85; }

  /* Scroll progress bar */
  .scroll-progress {
    position: fixed; top: 56px; left: 0; height: 2px;
    background: var(--accent); z-index: 101; width: 0%;
    transition: width 0.1s linear;
  }

  /* ── Hero ─────────────────────────────────── */
  .hero {
    min-height: 100vh; display: flex; align-items: center;
    padding: 7rem 1.5rem 5rem; position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 700px 500px at 20% 40%, rgba(62,207,142,0.05), transparent),
      radial-gradient(ellipse 500px 400px at 80% 60%, rgba(34,211,238,0.04), transparent);
  }
  .hero-grid {
    max-width: 1120px; margin: 0 auto; width: 100%;
