---
import Landing from '../layouts/Landing.astro';
---

<Landing>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <div class="nav-left">
        <a href="/" class="nav-logo">J.A.R.V.I.S.</a>
        <span class="nav-version">v0.1.0</span>
      </div>
      <div class="nav-right">
        <a href="#capabilities" class="nav-link">Features</a>
        <a href="/docs/introduction" class="nav-link">Docs</a>
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="nav-link">GitHub</a>
        <a href="/docs/installation" class="nav-install">INSTALL</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid">

      <!-- Left: copy -->
      <div>
        <p class="label">Always-on autonomous daemon</p>

        <h1 class="hero-heading">
          The AI that<br/>operates, not<br/>assists.
        </h1>

        <p class="hero-sub">
          Browser control. Desktop automation. Voice interface. Multi-agent delegation.
          Runs 24/7 in the background on your machine. Self-hosted. Open source.
        </p>

        <div class="hero-actions">
          <a href="/docs/installation" class="btn-solid">Get Started</a>
          <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="btn-border">View Source</a>
        </div>

        <!-- Install command -->
        <div class="cmd-block">
          <code><span class="cmd-prompt">$</span> curl -fsSL <span class="cmd-highlight">https://...install.sh</span> | bash</code>
          <button class="cmd-copy" id="copy-btn">copy</button>
        </div>
      </div>

      <!-- Right: system status panel -->
      <div class="status-panel">
        <div class="status-header">
          <div class="status-header-left">
            <span class="dot dot-green dot-pulse"></span>
            <span class="status-title">System Status</span>
          </div>
          <span class="status-time">02:14:33 UTC</span>
        </div>

        <div class="status-body">
          <div class="status-row">
            <span class="status-label">daemon</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">online</span></span>
            <span class="status-meta">pid 4821 · port 3142</span>
          </div>
          <div class="status-row">
            <span class="status-label">browser</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">ready</span></span>
            <span class="status-meta">chromium 121 · cdp:9222</span>
          </div>
          <div class="status-row">
            <span class="status-label">sidecar</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">active</span></span>
            <span class="status-meta">.NET 8 · tcp:9224</span>
          </div>
          <div class="status-row">
            <span class="status-label">voice</span>
            <span class="status-value"><span class="dot dot-cyan"></span><span class="status-cyan">listening</span></span>
            <span class="status-meta">wake-word · tts:edge</span>
          </div>
          <div class="status-row">
            <span class="status-label">agents</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">11 roles</span></span>
            <span class="status-meta">0 active · 0 queued</span>
          </div>
          <div class="status-row">
            <span class="status-label">memory</span>
            <span class="status-value"><span class="dot dot-green"></span><span class="status-green">847 facts</span></span>
            <span class="status-meta">12 entities · sqlite</span>
          </div>
          <div class="status-row status-row-last">
            <span class="status-label">proactive</span>
            <span class="status-value"><span class="dot dot-amber"></span><span class="status-amber">3 tasks</span></span>
            <span class="status-meta">next: 14:00 · gmail watch</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section id="capabilities" class="section section-border">
    <div class="container">

      <div class="fade-in section-head">
        <p class="section-label">Capabilities</p>
        <h2 class="section-heading">What JARVIS controls</h2>
      </div>

      <div class="cap-stack">
        <!-- Browser -->
        <div class="fade-in cap-row">
          <div>
            <div class="cap-title"><span class="dot dot-green"></span><h3>Browser Control</h3></div>
            <p class="cap-desc">
              Full Chromium automation via Chrome DevTools Protocol. Navigate pages, click elements,
              fill forms, extract data, take screenshots. Stealth mode bypasses bot detection.
              Auto-launches with an isolated profile.
            </p>
            <div class="tags">
              <span class="tag">navigate</span><span class="tag">click</span><span class="tag">type</span><span class="tag">extract</span><span class="tag">screenshot</span>
            </div>
          </div>
          <div class="code-panel">
            <div class="code-comment"># JARVIS browsing autonomously</div>
            <div><span class="code-fn">navigate</span> <span class="code-str">"https://github.com/trending"</span></div>
            <div><span class="code-fn">extract</span> <span class="code-str">"top 5 trending repos"</span></div>
            <div><span class="code-fn">click</span> <span class="code-str">"[3] Star button"</span></div>
            <div><span class="code-fn">screenshot</span> <span class="code-str">full_page=true</span></div>
          </div>
        </div>

        <!-- Desktop -->
        <div class="fade-in cap-row">
          <div class="code-panel">
            <div class="code-comment"># Control any Windows app</div>
            <div><span class="code-fn2">list_windows</span></div>
            <div class="code-comment">  [1] Slack · [2] VS Code · [3] Excel</div>
            <div><span class="code-fn2">focus_window</span> <span class="code-str">"Excel"</span></div>
            <div><span class="code-fn2">click_element</span> <span class="code-str">"[14] Cell A1"</span></div>
            <div><span class="code-fn2">type_text</span> <span class="code-str">"Q4 Revenue"</span></div>
          </div>
          <div>
            <div class="cap-title"><span class="dot dot-green"></span><h3>Desktop Control</h3></div>
            <p class="cap-desc">
              Native Windows application automation via FlaUI sidecar. List windows, click buttons,
              read text, type keystrokes, take screenshots. Works with any desktop app including
              legacy software. Multi-monitor support. Auto-launches from WSL.
            </p>
            <div class="tags">
              <span class="tag">FlaUI</span><span class="tag">.NET 8</span><span class="tag">TCP 9224</span><span class="tag">WSL bridge</span>
            </div>
          </div>
        </div>

        <!-- Voice -->
        <div class="fade-in cap-row">
          <div>
            <div class="cap-title"><span class="dot dot-cyan"></span><h3>Voice Interface</h3></div>
            <p class="cap-desc">
              "Hey JARVIS" wake word detection via ONNX neural network. Speech-to-text via
              OpenAI Whisper, Groq, or local models. Text-to-speech via Edge TTS. Binary
              WebSocket protocol for streaming audio.
            </p>
            <div class="tags">
              <span class="tag">wake word</span><span class="tag">whisper STT</span><span class="tag">edge TTS</span><span class="tag">binary WS</span>
            </div>
          </div>
          <div class="code-panel">
            <div class="code-comment"># Voice state machine</div>
            <div><span class="code-comment">state:</span> <span class="code-fn2">idle</span> <span class="code-comment">→</span> <span class="status-amber">wake_detected</span></div>
            <div><span class="code-comment">state:</span> <span class="status-amber">wake_detected</span> <span class="code-comment">→</span> <span class="code-fn">listening</span></div>
            <div><span class="code-comment">stt:</span> <span class="code-str">"check my email"</span></div>
            <div><span class="code-comment">state:</span> <span class="code-fn">listening</span> <span class="code-comment">→</span> <span class="code-fn2">processing</span></div>
            <div><span class="code-comment">tts:</span> <span class="code-str">"You have 3 new emails..."</span></div>
          </div>
        </div>

        <!-- Multi-Agent -->
        <div class="fade-in cap-row">
          <div class="code-panel">
            <div class="code-comment"># Parallel agent delegation</div>
            <div><span class="status-amber">manage_agents</span> {'{'}</div>
            <div class="code-indent"><span class="code-str">agents:</span> [</div>
            <div class="code-indent2">{'{ role: '}<span class="code-fn">"researcher"</span>{', task: '}<span class="code-str">"..." }</span></div>
            <div class="code-indent2">{'{ role: '}<span class="code-fn">"coder"</span>{', task: '}<span class="code-str">"..." }</span></div>
            <div class="code-indent2">{'{ role: '}<span class="code-fn">"analyst"</span>{', task: '}<span class="code-str">"..." }</span></div>
            <div class="code-indent">]</div>
            <div>{'}'}</div>
          </div>
          <div>
            <div class="cap-title"><span class="dot dot-amber"></span><h3>Multi-Agent System</h3></div>
            <p class="cap-desc">
              Delegate to 11 specialist agent roles: researcher, coder, writer, analyst,
              sysadmin, and more. Synchronous single-agent delegation or parallel
              multi-agent teams. Each sub-agent has its own tool loop.
            </p>
            <div class="tags">
              <span class="tag">delegate_task</span><span class="tag">manage_agents</span><span class="tag">11 roles</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Smaller cards -->
      <div class="fade-in cap-small-grid">
        <div class="cap-small">
          <div class="cap-title"><span class="dot dot-green"></span><h3>Proactive Agent</h3></div>
          <p class="cap-desc-sm">
            Commitment executor, Gmail and Calendar observers, D-Bus notifications.
            JARVIS keeps promises, monitors your inbox, and alerts you — all autonomously.
          </p>
        </div>
        <div class="cap-small">
          <div class="cap-title"><span class="dot dot-green"></span><h3>Memory & Knowledge</h3></div>
          <p class="cap-desc-sm">
            Persistent SQLite knowledge vault. Automatic fact extraction after every conversation.
            Semantic search injects relevant context into every message.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CHANNELS -->
  <section class="section section-border">
    <div class="container">
      <div class="fade-in section-head">
        <p class="section-label">Channels</p>
        <h2 class="section-heading">Reachable everywhere</h2>
      </div>

      <div class="fade-in channel-grid">
        <div class="channel-card">
          <div class="channel-head"><span class="dot dot-green"></span><span class="channel-name">Dashboard</span></div>
          <span class="channel-meta">localhost:3142</span>
        </div>
        <div class="channel-card">
          <div class="channel-head"><span class="dot dot-green"></span><span class="channel-name">Telegram</span></div>
          <span class="channel-meta">voice + text + images</span>
        </div>
        <div class="channel-card">
          <div class="channel-head"><span class="dot dot-green"></span><span class="channel-name">Discord</span></div>
          <span class="channel-meta">bot commands + DMs</span>
        </div>
        <div class="channel-card">
          <div class="channel-head"><span class="dot dot-green"></span><span class="channel-name">Gmail</span></div>
          <span class="channel-meta">observer + read</span>
        </div>
        <div class="channel-card">
          <div class="channel-head"><span class="dot dot-green"></span><span class="channel-name">Calendar</span></div>
          <span class="channel-meta">alerts + scheduling</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SETUP -->
  <section class="section section-border">
    <div class="container-narrow">
      <div class="fade-in section-head">
        <p class="section-label">Setup</p>
        <h2 class="section-heading">Three commands. That's it.</h2>
      </div>

      <div class="fade-in terminal">
        <div class="terminal-header">
          <div class="terminal-dots">
            <div class="td td-red"></div>
            <div class="td td-yellow"></div>
            <div class="td td-green"></div>
          </div>
          <span class="terminal-label">bash</span>
        </div>
        <div class="terminal-body">
          <div class="code-comment"># 1. Install</div>
          <div><span class="code-comment">$</span> <span class="cmd-highlight">curl -fsSL https://raw.githubusercontent.com/vierisid/jarvis/main/install.sh | bash</span></div>
          <br/>
          <div class="code-comment"># 2. Configure</div>
          <div><span class="code-comment">$</span> <span class="cmd-highlight">jarvis onboard</span></div>
          <div class="code-fn"> ✓ LLM configured · ✓ Browser found · ✓ Sidecar built</div>
          <br/>
          <div class="code-comment"># 3. Launch</div>
          <div><span class="code-comment">$</span> <span class="cmd-highlight">jarvis start</span></div>
          <div class="code-fn"> ✓ JARVIS daemon started (PID 4821)</div>
          <div class="code-comment">   Dashboard: http://localhost:3142</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-border">
    <div class="fade-in cta">
      <h2 class="cta-heading">Deploy your own JARVIS.</h2>
      <p class="cta-sub">Open source. Self-hosted. No subscriptions. Full ownership of your AI.</p>
      <div class="cta-actions">
        <a href="/docs/installation" class="btn-solid">Read the Docs</a>
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="btn-border">Star on GitHub</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="footer-logo">J.A.R.V.I.S.</span>
        <span class="footer-copy">&copy; 2026</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener">GitHub</a>
        <a href="/docs/introduction">Docs</a>
        <a href="https://discord.gg/jarvis-ai" target="_blank" rel="noopener">Discord</a>
      </div>
    </div>
  </footer>

</Landing>

<style>
  /* ── Nav ──────────────────────────────────── */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1120px; margin: 0 auto; padding: 0 1.5rem;
    height: 56px; display: flex; align-items: center; justify-content: space-between;
  }
  .nav-left { display: flex; align-items: center; gap: 0.75rem; }
  .nav-logo {
    font-family: var(--mono); font-size: 0.875rem; font-weight: 700;
    color: var(--text-primary); text-decoration: none; letter-spacing: 0.08em;
  }
  .nav-version {
    font-family: var(--mono); font-size: 0.6875rem;
    color: var(--text-muted); font-weight: 500;
  }
  .nav-right { display: flex; align-items: center; gap: 1.75rem; }
  .nav-link {
    color: var(--text-secondary); text-decoration: none;
    font-size: 0.8125rem; font-weight: 500; transition: color 0.15s;
  }
  .nav-link:hover { color: var(--text-primary); }
  .nav-install {
    font-family: var(--mono); font-size: 0.75rem; font-weight: 600;
    color: var(--bg); background: var(--text-primary);
    padding: 0.375rem 0.875rem; border-radius: 4px;
    text-decoration: none; transition: opacity 0.15s;
  }
  .nav-install:hover { opacity: 0.85; }

  /* ── Hero ─────────────────────────────────── */
  .hero {
    min-height: 100vh; display: flex; align-items: center;
    padding: 7rem 1.5rem 5rem;
  }
  .hero-grid {
    max-width: 1120px; margin: 0 auto; width: 100%;
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
  }
  .label {
    font-family: var(--mono); font-size: 0.75rem; font-weight: 600;
    color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase;
    margin: 0 0 1.25rem;
  }
  .hero-heading {
    font-size: 3.25rem; font-weight: 900; line-height: 1.05;
    color: var(--text-primary); margin: 0 0 1.5rem; letter-spacing: -0.03em;
  }
  .hero-sub {
    font-size: 1rem; line-height: 1.7; color: var(--text-secondary);
    margin: 0 0 2rem; max-width: 440px;
  }
  .hero-actions {
    display: flex; gap: 0.75rem; align-items: center;
    flex-wrap: wrap; margin-bottom: 2rem;
  }

  /* ── Buttons ──────────────────────────────── */
  .btn-solid {
    font-size: 0.875rem; font-weight: 600; color: var(--bg);
    background: var(--text-primary); padding: 0.625rem 1.5rem;
    border-radius: 6px; text-decoration: none; transition: opacity 0.15s;
  }
  .btn-solid:hover { opacity: 0.85; }
  .btn-border {
    font-size: 0.875rem; font-weight: 500; color: var(--text-secondary);
    border: 1px solid var(--border); padding: 0.625rem 1.5rem;
    border-radius: 6px; text-decoration: none; transition: all 0.15s;
  }
  .btn-border:hover { border-color: #333; color: var(--text-primary); }

  /* ── Install cmd ──────────────────────────── */
  .cmd-block {
    font-family: var(--mono); font-size: 0.8125rem;
    background: var(--bg-raised); border: 1px solid var(--border);
    border-radius: 6px; padding: 0.75rem 1rem;
    display: flex; align-items: center; justify-content: space-between;
    max-width: 480px; gap: 0.75rem;
  }
  .cmd-block code { color: var(--text-secondary); overflow-x: auto; white-space: nowrap; }
  .cmd-prompt { color: var(--text-muted); }
  .cmd-highlight { color: var(--text-primary); }
  .cmd-copy {
    font-family: var(--mono); font-size: 0.6875rem; font-weight: 600;
    color: var(--text-muted); background: none; border: 1px solid var(--border);
    padding: 0.25rem 0.5rem; border-radius: 3px; cursor: pointer;
    text-transform: uppercase; letter-spacing: 0.05em; transition: all 0.15s;
  }
  .cmd-copy:hover { border-color: #333; color: #aaa; }

  /* ── Status Panel ─────────────────────────── */
  .status-panel {
    font-family: var(--mono); font-size: 0.8125rem;
    background: var(--bg-raised); border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
  }
  .status-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 1rem; border-bottom: 1px solid var(--border);
    background: var(--bg-surface);
  }
  .status-header-left { display: flex; align-items: center; gap: 0.5rem; }
  .status-title {
    font-weight: 600; color: var(--text-primary);
    font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .status-time { color: var(--text-muted); font-size: 0.6875rem; }
  .status-row {
    display: grid; grid-template-columns: 100px 80px 1fr;
    padding: 0.625rem 1rem; border-bottom: 1px solid var(--border-subtle);
    align-items: center;
  }
  .status-row-last { border-bottom: none; }
  .status-label { color: var(--text-muted); }
  .status-value { display: flex; align-items: center; gap: 0.375rem; }
  .status-meta { color: var(--text-muted); text-align: right; }
  .status-green { color: var(--accent); font-weight: 500; }
  .status-cyan { color: var(--accent-cyan); font-weight: 500; }
  .status-amber { color: var(--accent-amber); font-weight: 500; }

  /* ── Sections ─────────────────────────────── */
  .section { padding: 5rem 1.5rem; }
  .section-border { border-top: 1px solid var(--border); }
  .container { max-width: 1120px; margin: 0 auto; }
  .container-narrow { max-width: 720px; margin: 0 auto; }
  .section-head { margin-bottom: 3rem; }
  .section-label {
    font-family: var(--mono); font-size: 0.6875rem; font-weight: 600;
    color: var(--text-muted); letter-spacing: 0.12em; text-transform: uppercase;
    margin: 0 0 0.75rem;
  }
  .section-heading {
    font-size: 2rem; font-weight: 800; color: var(--text-primary);
    margin: 0; letter-spacing: -0.02em;
  }

  /* ── Capability blocks ────────────────────── */
  .cap-stack {
    display: flex; flex-direction: column; gap: 1px;
    background: var(--border);
  }
  .cap-row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;
    background: var(--bg); padding: 3rem 0; align-items: start;
  }
  .cap-title {
    display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1rem;
  }
  .cap-title h3 {
    font-family: var(--mono); font-size: 0.9375rem; font-weight: 700;
    color: var(--text-primary); margin: 0;
  }
  .cap-desc {
    font-size: 0.9375rem; line-height: 1.7; color: var(--text-secondary);
    margin: 0 0 1.25rem;
  }
  .cap-desc-sm {
    font-size: 0.875rem; line-height: 1.65; color: var(--text-secondary); margin: 0;
  }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag {
    font-family: var(--mono); font-size: 0.6875rem; color: var(--text-muted);
    background: var(--bg-raised); border: 1px solid var(--border);
    padding: 0.25rem 0.5rem; border-radius: 3px;
  }

  .cap-small-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
    background: var(--border); margin-top: 1px;
  }
  .cap-small { background: var(--bg); padding: 2rem; }

  /* ── Code panels ──────────────────────────── */
  .code-panel {
    font-family: var(--mono); font-size: 0.75rem;
    background: var(--bg-raised); border: 1px solid var(--border);
    border-radius: 6px; padding: 1rem 1.25rem; line-height: 1.8;
  }
  .code-comment { color: var(--text-muted); }
  .code-fn { color: var(--accent); }
  .code-fn2 { color: var(--accent-cyan); }
  .code-str { color: var(--text-secondary); }
  .code-indent { padding-left: 1rem; }
  .code-indent2 { padding-left: 2rem; }

  /* ── Channel grid ─────────────────────────── */
  .channel-grid { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .channel-card {
    font-family: var(--mono); font-size: 0.8125rem;
    background: var(--bg-raised); border: 1px solid var(--border);
    border-radius: 6px; padding: 1rem 1.25rem; flex: 1; min-width: 180px;
  }
  .channel-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.625rem; }
  .channel-name { font-weight: 600; color: var(--text-primary); }
  .channel-meta { color: var(--text-muted); }

  /* ── Terminal ─────────────────────────────── */
  .terminal {
    font-family: var(--mono); font-size: 0.8125rem;
    background: var(--bg-raised); border: 1px solid var(--border);
    border-radius: 8px; overflow: hidden;
  }
  .terminal-header {
    display: flex; align-items: center; padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--border); background: var(--bg-surface);
  }
  .terminal-dots { display: flex; gap: 0.375rem; }
  .td { width: 10px; height: 10px; border-radius: 50%; }
  .td-red { background: #ff5f56; }
  .td-yellow { background: #ffbd2e; }
