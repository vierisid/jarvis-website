<script is:inline>
(function(){
  var reduce=matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.documentElement.classList.add('js');

  /* reveals · base visible without JS, hidden only once JS owns them */
  var io='IntersectionObserver' in window;
  if(io && !reduce){
    var ob=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting){en.target.classList.add('vis');ob.unobserve(en.target);}});},{rootMargin:'0px 0px -8% 0px'});
    document.querySelectorAll('.rv').forEach(function(el){ob.observe(el);});
  } else {
    document.querySelectorAll('.rv').forEach(function(el){el.classList.add('vis');});
  }

  /* cursor pebble · carried liquid */
  var cp=document.getElementById('cpeb');
  (function(){
    var lerp=reduce?1:.16,mx=innerWidth*.5,my=innerHeight*.32,px=mx,py=my,vx=0,vy=0,ang=45,idle=0,still=0;
    cp.style.transition='opacity .6s var(--ease)';
    addEventListener('pointermove',function(e){mx=e.clientX+18;my=e.clientY+20;idle=16;still=0;},{passive:true});
    (function tick(){
      var nx=px+(mx-px)*lerp, ny=py+(my-py)*lerp;
      vx=nx-px;vy=ny-py;px=nx;py=ny;
      var sp=reduce?0:Math.min(Math.hypot(vx,vy)/26,1);
      if(sp>.02)ang=Math.atan2(vy,vx)*180/Math.PI+45;
      var s=sp*.32;
      cp.style.transform='translate('+(px-14)+'px,'+(py-14)+'px) rotate('+ang+'deg) scale('+(1+s)+','+(1-s*.55)+')';
      if(idle>0){idle--;cp.classList.add('moving');}else{cp.classList.remove('moving');}
      still++;cp.style.opacity=still>240?.6:1;
      requestAnimationFrame(tick);
    })();
  })();

  /* the demo · jarvis books, you approve */
  var demo=document.getElementById('demo'),jcur=document.getElementById('jcur'),ycur=document.getElementById('ycur'),
      jpeb=document.getElementById('jpeb'),f1=document.getElementById('f1'),f2=document.getElementById('f2'),
      t1=document.getElementById('t1'),t2=document.getElementById('t2'),pay=document.getElementById('pay'),
      appr=document.getElementById('appr'),apok=document.getElementById('apok'),toast=document.getElementById('toast');
  function peb(s){jpeb.className='gd'+(s?' '+s:'');}
  function at(el,dx,dy){var d=demo.getBoundingClientRect(),r=el.getBoundingClientRect();return{x:r.left-d.left+(dx||0),y:r.top-d.top+(dy||0)};}
  function move(cur,p,ms){cur.style.transition='transform '+(ms||1000)+'ms var(--ease)';cur.style.transform='translate('+p.x+'px,'+p.y+'px)';}
  var timers=[],running=false;
  function later(fn,ms){timers.push(setTimeout(fn,ms));}
  function type(el,fld,str,done){
    fld.classList.add('typing');var i=0;
    var iv=setInterval(function(){el.textContent=str.slice(0,++i);if(i>=str.length){clearInterval(iv);fld.classList.remove('typing');done&&done();}},38);
    timers.push(iv);
  }
  function reset(){
    timers.forEach(function(t){clearTimeout(t);clearInterval(t);});timers=[];
    t1.textContent='';t2.textContent='';
    f1.classList.remove('hot','typing');f2.classList.remove('hot','typing');
    pay.classList.remove('hot','paid');pay.textContent='Pay €128.40';
    appr.classList.remove('show');apok.classList.remove('press');toast.classList.remove('show');
    peb('');
    move(jcur,{x:demo.clientWidth*.06,y:demo.clientHeight*.18},0);
    move(ycur,{x:demo.clientWidth*.74,y:demo.clientHeight*.66},0);
  }
  function pose(){ /* reduced-motion still frame: the asking moment */
    reset();t1.textContent='Vieri Balboni';t2.textContent='LH1812 · 09:00';
    pay.classList.add('hot');appr.classList.add('show');peb('s-ask');
    move(jcur,at(pay,70,-6),0);move(ycur,at(apok,40,18),0);
  }
  function run(){
    if(!running)return;
    reset();
    later(function(){peb('s-think');move(jcur,at(f1,150,12),900);},500);
    later(function(){peb('');f1.classList.add('hot');type(t1,f1,'Vieri Balboni');},1500);
    later(function(){f1.classList.remove('hot');f2.classList.add('hot');move(jcur,at(f2,150,12),650);},2400);
    later(function(){type(t2,f2,'LH1812 · 09:00');},2950);
    later(function(){f2.classList.remove('hot');move(jcur,at(pay,70,-6),750);},3900);
    later(function(){pay.classList.add('hot');peb('s-ask');appr.classList.add('show');},4700);
    later(function(){move(ycur,at(apok,40,18),900);},5600);
    later(function(){apok.classList.add('press');},6700);
    later(function(){apok.classList.remove('press');appr.classList.remove('show');pay.classList.remove('hot');pay.classList.add('paid');pay.textContent='Paid ✓';peb('s-done');toast.classList.add('show');},7050);
    later(function(){move(ycur,{x:demo.clientWidth*.74,y:demo.clientHeight*.66},900);peb('');},8100);
    later(function(){toast.classList.remove('show');},10300);
    later(run,11200);
  }
  var mb=document.getElementById('menuBtn'),mn=document.getElementById('mobnav');
  if(mb&&mn){
    mb.addEventListener('click',function(){var open=!mn.classList.contains('open');mn.classList.toggle('open',open);mb.setAttribute('aria-expanded',open);});
    mn.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){mn.classList.remove('open');mb.setAttribute('aria-expanded',false);});});
  }
  var tc=document.getElementById('tcopy');
  if(tc)tc.addEventListener('click',function(){
    navigator.clipboard.writeText('bun install -g @usejarvis/brain\njarvis onboard\njarvis start').then(function(){tc.textContent='copied ✓';setTimeout(function(){tc.textContent='copy';},1600);});
  });

  if(reduce){pose();}
  else if(io){
    new IntersectionObserver(function(es){es.forEach(function(en){
      if(en.isIntersecting&&!running){running=true;run();}
      else if(!en.isIntersecting&&running){running=false;reset();}
    });},{threshold:.35}).observe(demo);
  } else {running=true;run();}
})();
</script>
</body>
