  .arch-inner { max-width: 860px; margin: 0 auto; }

  .arch-diagram {
    font-family: var(--mono);
    margin: 3rem 0 2rem;
  }

  .arch-layer {
    border: 1px solid var(--border); border-radius: 8px;
    padding: 1.25rem; background: var(--bg-raised);
  }
  .arch-layer-label {
    font-size: 0.5625rem; font-weight: 700;
