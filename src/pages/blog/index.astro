---
import Brand from '../../layouts/Brand.astro';

const posts = [
  { slug: 'the-agent-ecosystem-2026', title: 'The Agent Ecosystem in 2026: Where Usejarvis Fits In', description: 'A landscape analysis of autonomous AI agents, from research to production, and how different approaches solve different problems.', date: 'April 11, 2026', readTime: '8 min' },
  { slug: 'long-context-models-agent-future', title: 'Long Context Models and the Agent Future', description: 'Why 200k+ context windows unlock truly autonomous AI agents — and what that means for systems like Usejarvis', date: 'April 11, 2026', readTime: '6 min' },
  { slug: 'ai-agent-trends-2026', title: "AI Agent Trends in 2026: What's Actually Happening", description: "The gap between hype and reality in AI agents is widening. Here's what's actually working, and why Usejarvis took a different path.", date: 'April 11, 2026', readTime: '7 min' },
  { slug: 'what-jarvis-can-do', title: 'What Usejarvis Can Do: Beyond the Chat Interface', description: 'An autonomous AI agent that sees your screen, controls your apps, and pursues goals on your behalf.', date: 'April 11, 2026', readTime: '5 min' },
  { slug: 'self-hosting-vs-opencove', title: 'Self-Hosting vs. OpenCove: Choosing Your Usejarvis Deployment', description: 'Understanding the tradeoffs between running Usejarvis on your own infrastructure versus using our managed cloud.', date: 'April 11, 2026', readTime: '6 min' },
  { slug: 'jarvis-vs-claude-code', title: 'Usejarvis vs. Claude Code: Different Tools for Different Jobs', description: 'Why an autonomous agent runtime and an AI coding assistant solve fundamentally different problems.', date: 'April 11, 2026', readTime: '7 min' },
];

const [featured, ...rest] = posts;
---

<Brand title="Blog · usejarvis" description="Field notes from the runtime — deep dives, design decisions, and context that didn't fit in the docs." active="blog">
  <!-- ── HEADER ── -->
  <header class="blog-head">
    <div class="blog-head-inner">
      <p class="label-mono reveal reveal-up">Field notes</p>
      <h1 class="display-h1 reveal reveal-up" style="margin:14px 0 20px;max-width:14ch">Notes from the <em>runtime.</em></h1>
      <p class="lead reveal reveal-up">Deep dives, design decisions, and pieces of context that didn't fit in the docs.</p>
    </div>
  </header>

  <!-- ── FEATURED POST ── -->
  <section class="blog-featured">
    <div class="blog-featured-inner">
      <a href={`/blog/${featured.slug}`} class="featured-card reveal reveal-up">
        <div class="featured-meta">
          <span class="label-mono">Latest</span>
          <span class="featured-sep">·</span>
          <span class="featured-meta-text">{featured.date} · {featured.readTime} read</span>
        </div>
        <h2 class="featured-title">{featured.title}</h2>
        <p class="featured-desc">{featured.description}</p>
        <span class="featured-arrow">Read post →</span>
      </a>
    </div>
  </section>

  <!-- ── POST LIST ── -->
  <section class="blog-list">
    <div class="blog-list-inner">
      <p class="label-mono reveal reveal-up blog-list-label">Archive</p>
      <div class="post-grid">
        {rest.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-card reveal reveal-up">
            <div class="post-card-meta">
              <span>{post.date}</span>
              <span class="post-card-sep">·</span>
              <span>{post.readTime} read</span>
            </div>
            <h3 class="post-card-title">{post.title}</h3>
            <p class="post-card-desc">{post.description}</p>
            <span class="post-card-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Brand>

<style>
  .blog-head { background: linear-gradient(180deg, var(--panel2), var(--bg)); border-bottom: 1px solid var(--rule); }
  .blog-head-inner { max-width: 1100px; margin: 0 auto; padding: 84px 32px 60px; }
  @media (max-width: 700px) { .blog-head-inner { padding: 60px 20px 48px; } }

  /* featured */
  .blog-featured { background: var(--panel2); border-bottom: 1px solid var(--rule); }
  .blog-featured-inner { max-width: 1100px; margin: 0 auto; padding: 52px 32px; }
  .featured-card { display: block; background: var(--raise); border: 1px solid var(--rule); border-radius: var(--corner); padding: 36px 40px; text-decoration: none; color: var(--ink); box-shadow: var(--sh-lg), 0 0 0 1px rgba(230,59,46,.1); transition: transform .2s var(--ease), box-shadow .2s var(--ease); }
  .featured-card:hover { transform: translateY(-2px); box-shadow: var(--sh-lg), 0 0 0 1px rgba(230,59,46,.3); }
  .featured-meta { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .featured-sep { color: var(--rule); }
  .featured-meta-text { font-family: var(--mono); font-size: 12px; color: var(--ink3); }
  .featured-title { font-family: var(--sans); font-weight: 700; font-size: clamp(28px, 3.4vw, 38px); line-height: 1.12; letter-spacing: -.035em; color: var(--ink); margin: 0 0 16px; max-width: 26ch; }
  .featured-desc { font-size: 17px; line-height: 1.6; color: var(--ink2); margin: 0 0 22px; max-width: 60ch; }
  .featured-arrow { font-family: var(--mono); font-size: 13px; font-weight: 500; letter-spacing: .04em; color: var(--listen-tx); }
  @media (max-width: 640px) { .featured-card { padding: 28px 24px; } }

  /* list */
  .blog-list { background: var(--bg); }
  .blog-list-inner { max-width: 1100px; margin: 0 auto; padding: 68px 32px 110px; }
  @media (max-width: 700px) { .blog-list-inner { padding: 52px 20px 90px; } }
  .blog-list-label { margin-bottom: 22px; }
  .post-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: var(--corner); overflow: hidden; }
  .post-card { background: var(--raise); padding: 32px 32px 28px; text-decoration: none; color: var(--ink); display: flex; flex-direction: column; transition: background .2s var(--ease); }
  .post-card:hover { background: var(--panel2); }
  .post-card:hover .post-card-arrow { transform: translateX(4px); color: var(--listen-tx); }
  .post-card-meta { font-family: var(--mono); font-size: 12px; color: var(--ink3); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .post-card-sep { color: var(--rule); }
  .post-card-title { font-family: var(--sans); font-weight: 700; font-size: 22px; line-height: 1.22; letter-spacing: -.02em; color: var(--ink); margin: 0 0 12px; max-width: 28ch; }
  .post-card-desc { font-size: 15px; line-height: 1.6; color: var(--ink2); margin: 0 0 20px; flex: 1; }
  .post-card-arrow { align-self: flex-start; font-family: var(--mono); font-size: 18px; color: var(--ink3); transition: transform .2s var(--ease), color .2s var(--ease); }
  @media (max-width: 720px) { .post-grid { grid-template-columns: 1fr; } .post-card { padding: 24px; } }
</style>
