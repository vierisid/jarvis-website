---
import '../styles/brand.css';

export interface Props {
  title: string;
  description: string;
  /** og:type — "website" (default) or "article" */
  ogType?: string;
  /** which top-nav item to mark active: home | blog | roadmap | docs */
  active?: string;
}

const {
  title,
  description,
  ogType = 'website',
  active = '',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const links = [
  { href: '/#work', label: 'How it works', key: 'work' },
  { href: '/templates', label: 'Templates', key: 'templates' },
  { href: '/builders', label: 'Builders', key: 'builders' },
  { href: '/hosted', label: 'Hosted', key: 'hosted' },
  { href: '/#safety', label: 'Safety', key: 'safety' },
  { href: '/docs/introduction', label: 'Docs', key: 'docs' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><style>path{fill:%2313161A}@media(prefers-color-scheme:dark){path{fill:%23EEF1F4}}</style><path d="M29 3 L29 16 A13 13 0 1 1 16 3 Z"/></svg>' />
  <meta name="theme-color" content="#FAFBFC" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0B0D10" media="(prefers-color-scheme: dark)" />
  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="usejarvis" />
  <meta property="og:image" content={ogImage} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Familjen+Grotesk:ital,wght@0,400..700;1,400&family=Spline+Sans+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="nav"><div class="nav-in">
    <div class="nav-l">
      <a href="/" class="nav-l" style="text-decoration:none;gap:9px">
        <span class="ld"><span class="r"></span></span>
        <span class="lw"><span class="u">use</span>jarvis</span>
      </a>
      <div class="nav-links">
        {links.map((l) => (
          <a href={l.href} class={active === l.key ? 'active' : ''}>{l.label}</a>
        ))}
      </div>
    </div>
    <div class="nav-r">
      <span class="nav-status"><span class="d"></span>daemon · :3142</span>
      <a class="nav-discord" href="https://discord.gg/2HgF5krXrj" target="_blank" rel="noopener" aria-label="Join our Discord"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg></a>
      <a class="btn-solid" href="/docs/installation">Install</a>
      <button id="menuBtn" aria-expanded="false" aria-controls="mobnav">Menu</button>
    </div>
    <div id="mobnav">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href="/docs/installation">Install</a>
    </div>
  </div></nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="ld"><span class="r"></span></span>
        <span class="lw"><span class="u">use</span>jarvis</span>
        <span class="footer-copy">© 2026</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener">GitHub</a>
        <a href="/docs/introduction">Docs</a>
        <a href="/blog">Blog</a>
        <a href="/roadmap">Roadmap</a>
        <a href="/templates">Templates</a>
        <a href="/trust">Trust</a>
        <a href="https://github.com/vierisid/jarvis/blob/main/LICENSE" target="_blank" rel="noopener">License</a>
        <a href="https://discord.gg/2HgF5krXrj" target="_blank" rel="noopener">Discord</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    (function () {
      var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      document.documentElement.classList.add('js');
      if ('IntersectionObserver' in window && !reduce) {
        var ob = new IntersectionObserver(function (es) {
          es.forEach(function (en) { if (en.isIntersecting) { en.target.classList.add('visible'); ob.unobserve(en.target); } });
        }, { rootMargin: '0px 0px -8% 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { ob.observe(el); });
      } else {
        document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('visible'); });
      }
      var mb = document.getElementById('menuBtn'), mn = document.getElementById('mobnav');
      if (mb && mn) {
        mb.addEventListener('click', function () { var open = !mn.classList.contains('open'); mn.classList.toggle('open', open); mb.setAttribute('aria-expanded', open); });
        mn.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', function () { mn.classList.remove('open'); mb.setAttribute('aria-expanded', false); }); });
      }
    })();
  </script>
</body>
</html>
