---
import Brand from './Brand.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  readTime: string;
}

const { title, description, date, readTime } = Astro.props;
---

<Brand title={`${title} · usejarvis`} description={description} ogType="article" active="blog">
  <!-- ── ARTICLE HEADER ── -->
  <header class="post-head">
    <div class="post-head-inner">
      <a href="/blog" class="post-back"><span class="post-back-arrow">←</span><span>All posts</span></a>
      <p class="label-mono reveal reveal-up post-meta">
        <span>{date}</span><span class="post-meta-sep">·</span><span>{readTime} read</span>
      </p>
      <h1 class="display-h1 post-title reveal reveal-up">{title}</h1>
      <p class="lead post-lead reveal reveal-up">{description}</p>
    </div>
  </header>

  <!-- ── ARTICLE BODY ── -->
  <article class="post-body">
    <div class="post-body-inner"><slot /></div>
  </article>

  <!-- ── ARTICLE FOOTER ── -->
  <section class="post-cta">
    <div class="post-cta-inner">
      <p class="label-mono reveal reveal-up">Next up</p>
      <h2 class="display-h2 reveal reveal-up" style="margin:12px 0 26px">Read more from the <em>usejarvis</em> team.</h2>
      <div class="post-cta-actions reveal reveal-up">
        <a href="/blog" class="btn-solid">All posts</a>
        <a href="/docs/installation" class="btn-border">Install usejarvis</a>
      </div>
    </div>
  </section>
</Brand>

<style>
  .post-head { border-bottom: 1px solid var(--rule); background: linear-gradient(180deg, var(--panel2), var(--bg)); }
  .post-head-inner { max-width: 760px; margin: 0 auto; padding: 72px 28px 52px; }
  .post-back { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--ink3); text-decoration: none; margin-bottom: 28px; transition: color .2s var(--ease); }
  .post-back:hover { color: var(--listen-tx); }
  .post-back-arrow { display: inline-block; transition: transform .2s var(--ease); }
  .post-back:hover .post-back-arrow { transform: translateX(-2px); }
  .post-meta { display: inline-flex; align-items: center; gap: 10px; margin: 0 0 14px; }
  .post-meta-sep { color: var(--rule); }
  .post-title { max-width: 24ch; margin: 0 0 18px; font-size: clamp(32px, 4.4vw, 52px); }
  .post-lead { margin: 0; max-width: 60ch; }

  .post-body { background: var(--bg); }
  .post-body-inner { max-width: 760px; margin: 0 auto; padding: 52px 28px 90px; font-size: 17px; line-height: 1.75; color: var(--ink2); }
  .post-body-inner :global(h2) { font-family: var(--sans); font-weight: 700; font-size: clamp(24px, 3vw, 32px); line-height: 1.18; letter-spacing: -.03em; color: var(--ink); margin: 52px 0 16px; padding-top: 34px; border-top: 1px solid var(--rule); }
  .post-body-inner :global(h2:first-child) { margin-top: 0; padding-top: 0; border-top: none; }
  .post-body-inner :global(h3) { font-family: var(--sans); font-weight: 700; font-size: 20px; letter-spacing: -.02em; color: var(--ink); margin: 34px 0 12px; }
  .post-body-inner :global(p) { margin: 0 0 22px; max-width: 64ch; }
  .post-body-inner :global(strong) { color: var(--ink); font-weight: 600; }
  .post-body-inner :global(em) { font-style: italic; color: var(--ink); }
  .post-body-inner :global(a) { color: var(--listen-tx); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; transition: text-decoration-thickness .2s var(--ease); }
  .post-body-inner :global(a:hover) { text-decoration-thickness: 2px; }
  .post-body-inner :global(ul), .post-body-inner :global(ol) { margin: 0 0 24px; padding-left: 24px; max-width: 64ch; }
  .post-body-inner :global(li) { margin-bottom: 10px; }
  .post-body-inner :global(code) { font-family: var(--mono); font-size: .85em; background: var(--panel); border: 1px solid var(--rule); border-radius: var(--corner-sm); padding: .1em .42em; color: var(--ink); }
  .post-body-inner :global(pre) { background: var(--panel); border: 1px solid var(--rule); border-radius: var(--corner); padding: 18px 20px; overflow-x: auto; margin: 0 0 24px; font-size: 13.5px; line-height: 1.7; }
  .post-body-inner :global(pre code) { background: none; border: none; padding: 0; color: var(--ink); }
  .post-body-inner :global(blockquote) { margin: 32px 0; padding: 14px 18px; border-left: 2px solid var(--listen); background: var(--panel2); color: var(--ink2); border-radius: 0 var(--corner-sm) var(--corner-sm) 0; }
  .post-body-inner :global(.highlight-box) { background: var(--raise); border: 1px solid var(--rule); border-radius: var(--corner); padding: 24px 28px; margin: 32px 0; box-shadow: var(--sh-sm); }
  .post-body-inner :global(.highlight-box h3) { margin-top: 0; font-size: 18px; }
  .post-body-inner :global(.highlight-box p:last-child) { margin-bottom: 0; }
  .post-body-inner :global(hr) { border: none; border-top: 1px solid var(--rule); margin: 48px 0; }

  .post-cta { border-top: 1px solid var(--rule); background: var(--panel2); }
  .post-cta-inner { max-width: 760px; margin: 0 auto; padding: 68px 28px; }
  .post-cta-actions { display: flex; gap: 11px; flex-wrap: wrap; }
</style>
