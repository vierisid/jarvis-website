---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  date: string;
  readTime: string;
}

const { title, description, date, readTime } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <title>{title} — J.A.R.V.I.S.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        background: #0a0a0a;
        color: #a0a0a0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      :root {
        --bg: #0a0a0a;
        --bg-raised: #111111;
        --bg-surface: #161616;
        --border: #1e1e1e;
        --border-subtle: #161616;
        --text-primary: #e8e8e8;
        --text-secondary: #888888;
        --text-muted: #555555;
        --accent: #3ecf8e;
        --accent-amber: #e5a522;
        --accent-cyan: #22d3ee;
        --accent-red: #ef4444;
        --mono: 'JetBrains Mono', ui-monospace, monospace;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(10,10,10, 0.8);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 16px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav-left {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .nav-logo {
        font-family: var(--mono);
        font-size: 16px;
        font-weight: 700;
        color: var(--accent);
        text-decoration: none;
        letter-spacing: 0.5px;
      }
      .nav-version {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text-muted);
        background: var(--bg-surface);
        padding: 2px 8px;
        border-radius: 4px;
      }
      .nav-right {
        display: flex;
        gap: 24px;
        align-items: center;
      }
      .nav-link {
        font-size: 14px;
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.2s;
      }
      .nav-link:hover {
        color: var(--text-primary);
      }

      .blog-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 80px 24px;
      }

      .blog-header {
        margin-bottom: 48px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--border);
      }

      .blog-meta {
        display: flex;
        gap: 16px;
        align-items: center;
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 16px;
        font-family: var(--mono);
      }

      .blog-title {
        font-size: 48px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.2;
        margin: 0 0 16px 0;
      }

      .blog-description {
        font-size: 20px;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
      }

      .blog-content {
        font-size: 17px;
        line-height: 1.8;
        color: var(--text-secondary);
      }

      .blog-content h2 {
        font-size: 32px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 48px 0 24px 0;
        line-height: 1.3;
      }

      .blog-content h3 {
        font-size: 24px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 36px 0 16px 0;
      }

      .blog-content p {
        margin: 0 0 24px 0;
      }

      .blog-content ul, .blog-content ol {
        margin: 0 0 24px 0;
        padding-left: 24px;
      }

      .blog-content li {
        margin-bottom: 12px;
      }

      .blog-content code {
        font-family: var(--mono);
        font-size: 15px;
        background: var(--bg-surface);
        padding: 2px 8px;
        border-radius: 4px;
        color: var(--accent);
      }

      .blog-content pre {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
        overflow-x: auto;
        margin: 0 0 24px 0;
      }

      .blog-content pre code {
        background: none;
        padding: 0;
        color: var(--text-secondary);
      }

      .blog-content a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
      }

      .blog-content a:hover {
        border-bottom-color: var(--accent);
      }

      .blog-content strong {
        color: var(--text-primary);
        font-weight: 600;
      }

      .blog-content blockquote {
        margin: 32px 0;
        padding: 16px 24px;
        border-left: 3px solid var(--accent);
        background: var(--bg-surface);
        font-style: italic;
        color: var(--text-secondary);
      }

      .highlight-box {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 24px;
        margin: 32px 0;
      }

      .highlight-box h3 {
        margin-top: 0;
      }

      @media (max-width: 768px) {
        .blog-title {
          font-size: 36px;
        }
        .blog-description {
          font-size: 18px;
        }
        .nav-right {
          gap: 12px;
        }
      }
    </style>
  </head>
  <body>
    <!-- NAV -->
    <nav class="nav">
      <div class="nav-inner">
        <div class="nav-left">
          <a href="/" class="nav-logo">J.A.R.V.I.S.</a>
          <span class="nav-version">v0.4.2</span>
        </div>
        <div class="nav-right">
          <a href="/" class="nav-link">Home</a>
          <a href="/blog" class="nav-link">Blog</a>
          <a href="/docs/introduction" class="nav-link">Docs</a>
          <a href="https://github.com/vierisid/jarvis" target="_blank" rel="noopener" class="nav-link">GitHub</a>
        </div>
      </div>
    </nav>

    <div class="blog-container">
      <div class="blog-header">
        <div class="blog-meta">
          <span>{date}</span>
          <span>•</span>
          <span>{readTime} read</span>
        </div>
        <h1 class="blog-title">{title}</h1>
        <p class="blog-description">{description}</p>
      </div>

      <div class="blog-content">
        <slot />
      </div>
    </div>
  </body>
</html>
